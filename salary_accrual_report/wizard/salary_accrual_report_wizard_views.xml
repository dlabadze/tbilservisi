<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view for account.move.line (salary accrual report result) -->
    <record id="view_account_move_line_salary_accrual_list" model="ir.ui.view">
        <field name="name">account.move.line.salary.accrual.list</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <list string="ხელფასის დარიცხვის რეპორტი" create="false" delete="false" edit="false" default_group_by="partner_id">
                <field name="account_id" options="{'no_open': True}"/>
                <field name="date" string="თარიღი"/>
                <field name="partner_id"/>
                <field name="partner_vat" string="პირადი ნომერი"/>
                <field name="name"/>
                <field name="debit" sum="Total Debit"/>
                <field name="credit" sum="Total Credit"/>
            </list>
        </field>
    </record>

    <!-- Wizard form -->
    <record id="view_salary_accrual_report_wizard_form" model="ir.ui.view">
        <field name="name">salary.accrual.report.wizard.form</field>
        <field name="model">salary.accrual.report.wizard</field>
        <field name="arch" type="xml">
            <form string="ხელფასის დარიცხვის რეპორტი">
                <group>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_salary_accrual_report_wizard" model="ir.actions.act_window">
        <field name="name">ხელფასის დარიცხვის რეპორტი</field>
        <field name="res_model">salary.accrual.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_salary_accrual_report"
        name="ხელფასის დარიცხვის რეპორტი"
        action="action_salary_accrual_report_wizard"
        parent="account.account_reports_partners_reports_menu"
        sequence="20"/>

</odoo>
