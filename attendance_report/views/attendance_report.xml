<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_attendance" model="ir.actions.report">
        <field name="name">Attendance Report</field>
        <field name="model">attendance.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">attendance_report.attendance_report_template</field>
        <field name="report_file">attendance_report.attendance_report_template</field>
        <field name="binding_model_id" ref="model_attendance_report_wizard"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="attendance_report.paperformat_attendance_landscape"/>
    </record>

    <template id="attendance_report_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page">
                    <style>
                        .table-attendance {
                            font-size: 10px;
                            table-layout: fixed;
                            border-collapse: collapse;
                        }
                        .rotate-header {
                            height: 100px;
                            position: relative;
                            padding: 0 !important;
                            vertical-align: bottom !important;
                            border: 0.5px solid black !important;
                        }
                        .rotate-header > div {
                            position: absolute;
                            bottom: 5px;
                            left: 50%;
                            width: 100px;
                            margin-left: -5px;
                            -webkit-transform: rotate(-90deg);
                            transform: rotate(-90deg);
                            -webkit-transform-origin: 0 0;
                            transform-origin: 0 0;
                            white-space: nowrap;
                            text-align: left;

                        }
                        .summary-box {
                            background-color: #f8f9fa;
                            font-size: 11px;
                        }
                        .summary-table td {
                            padding: 2px 5px;
                            border: none !important;
                        }
                    </style>

                    <div class="summary-box border mb-3 p-2">
                        <table style="width: 100%; border: none;">
                            <tr>
                                <td style="width: 60%; vertical-align: top; border: none;">
                                    <div t-if="docs.department_id" class="mt-1">
                                        <strong>დეპარტამენტი:</strong> <t t-out="docs.department_id.name"/>
                                    </div>
                                </td>
                                <td style="width: 40%; text-align: right; vertical-align: top; border: none;">
                                        <strong>სამუშაო დროის აღრიცხვის ტაბელი<br/></strong><strong><t t-out="month_label"/> წ.</strong>
                                    <div class="mt-1">
                                        <strong>თვეში დღეები:</strong> <t t-out="last_day"/>
                                    </div>
                                </td>
                            </tr>
                        </table>
                        <div class="border-top mt-2 pt-2">
                             <table class="summary-table" style="width: 100%; font-size: 10px; border: none;">
                                 <tr>
                                     <td style="border: none;"><strong>სულ ნამუშევარი სთ:</strong> <t t-out="totals['hours']"/></td>
<!--                                     <td style="border: none;"><strong>ნამუშევარი:</strong> <t t-out="totals['x']"/></td>-->
                                     <td style="border: none;"><strong>სულ ბიულეტენი:</strong> <t t-out="totals['b']"/></td>
                                     <td style="border: none;"><strong>სულ დასვენება:</strong> <t t-out="totals['d']"/></td>
                                     <td style="border: none;"><strong>სულ გაცდენილი:</strong> <t t-out="totals['g']"/></td>
                                     <td style="border: none;"><strong>სულ შვებულება:</strong> <t t-out="totals['s']"/></td>
                                     <td style="border: none;"><strong>სულ შეუვსებელი:</strong> <t t-out="totals['empty']"/></td>
                                 </tr>
                             </table>
                        </div>
                    </div>

                    <table class="table table-bordered table-sm table-attendance">
                        <thead>
                            <tr class="bg-200">
                                <th style="width: 60px; vertical-align: middle;">სახელი,გვარი</th>
                                <th style="width: 80px; vertical-align: middle;">თანამდებობა</th>
                                <th style="width: 70px; vertical-align: middle;">პირადი N</th>
                                <t t-foreach="days_in_month" t-as="day">
                                    <th class="text-center" style="width: 20px; vertical-align: middle;"><t t-out="day"/></th>
                                </t>
                                <th class="rotate-header" style="width: 25px;"><div><span>ნამუშევარი</span></div></th>
                                <th class="rotate-header" style="width: 25px;"><div><span>გაცდენილი</span></div></th>
                                <th class="rotate-header" style="width: 25px;"><div><span>დასვენება</span></div></th>
                                <th class="rotate-header" style="width: 25px;"><div><span>შვებულება</span></div></th>
                                <th class="rotate-header" style="width: 25px;"><div><span>ბიულეტენი</span></div></th>
                                <th class="rotate-header" style="width: 25px;"><div><span>ცარიელი</span></div></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="report_lines" t-as="line">
                                <tr>
                                    <td><t t-out="line['name']"/></td>
                                    <td><t t-out="line['job']"/></td>
                                    <td><t t-out="line['identification_id']"/></td>
                                    <t t-foreach="days_in_month" t-as="day">
                                        <td class="text-center">
                                            <t t-out="line['days'].get(day, '')"/>
                                        </td>
                                    </t>
                                    <td class="text-center bg-light"><t t-out="line['total_x']"/></td>
                                    <td class="text-center bg-light"><t t-out="line['total_g']"/></td>
                                    <td class="text-center bg-light"><t t-out="line['total_d']"/></td>
                                    <td class="text-center bg-light"><t t-out="line['total_s']"/></td>
                                    <td class="text-center bg-light"><t t-out="line['total_b']"/></td>
                                    <td class="text-center bg-light"><t t-out="line['total_empty']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <div class="mt-5" style="font-size: 10px;">
                        <div class="row">
                            <div class="col-5">
                                <strong>განყოფილების უფროსი:_____________________</strong><br/><br/><br/>
                                <strong>ადმინისტრაციული სამსახური:_____________________</strong>
                            </div>
                            <div class="col-7 text-end">
                                <strong>სულ ნამუშევარი დღეების რაოდენობა:</strong> <t t-out="totals['x']"/>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
