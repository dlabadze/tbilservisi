<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PDF Report Action -->
    <record id="action_partner_currency_report_pdf" model="ir.actions.report">
        <field name="name">Partner Currency Movement Report</field>
        <field name="model">partner.currency.movement.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">partner_currency_movement_report.partner_currency_pdf</field>
        <field name="report_file">partner_currency_movement_report.partner_currency_pdf</field>
        <field name="print_report_name">'Partner Currency Movement Report - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_partner_currency_movement_report"/>
        <field name="binding_type">report</field>
    </record>

    <!-- PDF Report Template -->
    <template id="partner_currency_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="row">
                            <div class="col-12">
                                <h2 class="text-center">Partner Currency Movement Report</h2>
                                <div class="text-center">
                                    <p><strong>Period:</strong> <span t-esc="doc.date_from"/> to <span t-esc="doc.date_to"/></p>
                                    <p><strong>Company:</strong> <span t-esc="doc.company_id.name"/></p>
                                    <p><strong>Generated on:</strong> <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M:%S')"/></p>
                                </div>
                            </div>
                        </div>

                        <!-- Report Content -->
                        <div class="row mt-3">
                            <div class="col-12">
                                <t t-if="grouped_lines">
                                    <t t-foreach="grouped_lines.items()" t-as="partner_data">
                                        <t t-set="partner_id" t-value="partner_data[0]"/>
                                        <t t-set="partner_info" t-value="partner_data[1]"/>
                                        
                                        <!-- Partner Header -->
                                        <div class="mt-4">
                                            <h4 style="background-color: #f0f0f0; padding: 8px; border-left: 4px solid #007cba;">
                                                <strong><span t-esc="partner_info['partner'].name"/></strong>
                                                <small class="text-muted"> - <span t-esc="partner_info['partner'].category_id.name or 'No Category'"/></small>
                                            </h4>
                                        </div>

                                        <!-- Currency Groups -->
                                        <t t-foreach="partner_info['currencies'].items()" t-as="currency_data">
                                            <t t-set="currency_id" t-value="currency_data[0]"/>
                                            <t t-set="currency_info" t-value="currency_data[1]"/>
                                            
                                            <!-- Currency Subheader -->
                                            <div class="mt-3">
                                                <h5 style="background-color: #f8f9fa; padding: 5px; border-left: 3px solid #28a745;">
                                                    Currency: <strong><span t-esc="currency_info['currency'].name"/> (<span t-esc="currency_info['currency'].symbol"/>)</strong>
                                                </h5>
                                            </div>

                                            <!-- Account Details Table -->
                                            <table class="table table-sm table-bordered mt-2">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Account Code</th>
                                                        <th>Account Name</th>
                                                        <th class="text-right">Opening Balance</th>
                                                        <th class="text-right">Total Debit</th>
                                                        <th class="text-right">Total Credit</th>
                                                        <th class="text-right">Net Movement</th>
                                                        <th class="text-right">Closing Balance</th>
                                                        <th class="text-center"># Moves</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="currency_info['accounts']" t-as="line">
                                                        <tr>
                                                            <td><span t-esc="line.account_code"/></td>
                                                            <td><span t-esc="line.account_name"/></td>
                                                            <td class="text-right">
                                                                <span t-esc="'{:,.2f}'.format(line.opening_balance)"/>
                                                                <small class="text-muted"> <span t-esc="line.currency_symbol"/></small>
                                                            </td>
                                                            <td class="text-right">
                                                                <span t-esc="'{:,.2f}'.format(line.total_debit)"/>
                                                                <small class="text-muted"> <span t-esc="line.currency_symbol"/></small>
                                                            </td>
                                                            <td class="text-right">
                                                                <span t-esc="'{:,.2f}'.format(line.total_credit)"/>
                                                                <small class="text-muted"> <span t-esc="line.currency_symbol"/></small>
                                                            </td>
                                                            <td class="text-right" t-att-class="'text-success' if line.net_movement >= 0 else 'text-danger'">
                                                                <span t-esc="'{:,.2f}'.format(line.net_movement)"/>
                                                                <small class="text-muted"> <span t-esc="line.currency_symbol"/></small>
                                                            </td>
                                                            <td class="text-right" t-att-class="'text-success' if line.closing_balance >= 0 else 'text-danger'">
                                                                <strong><span t-esc="'{:,.2f}'.format(line.closing_balance)"/></strong>
                                                                <small class="text-muted"> <span t-esc="line.currency_symbol"/></small>
                                                            </td>
                                                            <td class="text-center"><span t-esc="line.move_line_count"/></td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </t>
                                    </t>

                                    <!-- Summary Totals -->
                                    <div class="mt-5">
                                        <h4>Report Summary</h4>
                                        <div class="row">
                                            <div class="col-6">
                                                <table class="table table-sm">
                                                    <tr>
                                                        <td><strong>Total Opening Balance:</strong></td>
                                                        <td class="text-right"><span t-esc="'{:,.2f}'.format(totals['opening_balance'])"/></td>
                                                    </tr>
                                                    <tr>
                                                        <td><strong>Total Debit:</strong></td>
                                                        <td class="text-right"><span t-esc="'{:,.2f}'.format(totals['total_debit'])"/></td>
                                                    </tr>
                                                    <tr>
                                                        <td><strong>Total Credit:</strong></td>
                                                        <td class="text-right"><span t-esc="'{:,.2f}'.format(totals['total_credit'])"/></td>
                                                    </tr>
                                                </table>
                                            </div>
                                            <div class="col-6">
                                                <table class="table table-sm">
                                                    <tr>
                                                        <td><strong>Net Movement:</strong></td>
                                                        <td class="text-right" t-att-class="'text-success' if totals['net_movement'] >= 0 else 'text-danger'">
                                                            <span t-esc="'{:,.2f}'.format(totals['net_movement'])"/>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td><strong>Total Closing Balance:</strong></td>
                                                        <td class="text-right" t-att-class="'text-success' if totals['closing_balance'] >= 0 else 'text-danger'">
                                                            <strong><span t-esc="'{:,.2f}'.format(totals['closing_balance'])"/></strong>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td><strong>Total Journal Entries:</strong></td>
                                                        <td class="text-right"><span t-esc="totals['move_count']"/></td>
                                                    </tr>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="text-center mt-5">
                                        <h5 class="text-muted">No partner currency movements found for the selected period and criteria.</h5>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo> 