<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Server action on stock moves list view -->
    <record id="action_dv_fix_move_valuation_to_standard_price" model="ir.actions.server">
        <field name="name">Fix valuation to Standard Price</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="binding_model_id" ref="stock.model_stock_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_dv_apply_standard_price_valuation_fix()</field>
    </record>

    <!-- Optional button on stock move form -->
    <record id="view_move_form_dv_fix_valuation" model="ir.ui.view">
        <field name="name">stock.move.form.dv.fix.valuation</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button
                    name="action_dv_apply_standard_price_valuation_fix"
                    type="object"
                    string="Fix Valuation to Standard Price"
                    class="oe_highlight"
                />
            </header>
        </field>
    </record>

    <!-- Add the boolean field to the stock move form for visibility -->
    <record id="view_move_form_dv_fix_valuation_field" model="ir.ui.view">
        <field name="name">stock.move.form.dv.fix.valuation.field</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="dv_fix_valuation_to_standard_price" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>

