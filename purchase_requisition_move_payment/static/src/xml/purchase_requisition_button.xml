<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="account_accountant.BankRecRecordFormButtonsHeaderLeft" t-inherit="account_accountant.BankRecRecordFormButtonsHeaderLeft" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_statusbar_buttons')]" position="inside">
            <button class="btn btn-warning ms-2"
                    t-if="data.state === 'valid'"
                    t-on-click="(ev) => this.actionOpenPurchaseRequisitionWizard()">
                <i class="fa fa-shopping-cart me-1"/>
                <span>Purchase Req.</span>
            </button>
        </xpath>
    </t>

</templates>
