<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mail_activity_schedule_view_form_ka" model="ir.ui.view">
        <field name="name">mail.activity.schedule.view.form.ka</field>
        <field name="model">mail.activity.schedule</field>
        <field name="inherit_id" ref="mail.mail_activity_schedule_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='plan_id']" position="attributes">
                <attribute name="string">გეგმა</attribute>
            </xpath>
            <xpath expr="//field[@name='date_deadline']" position="attributes">
                <attribute name="string">ვადა</attribute>
            </xpath>
        </field>
    </record>
</odoo>
