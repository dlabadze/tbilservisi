<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View for fetch.waybills.wizard1 -->
    <record id="view_fetch_waybills_wizard1_form" model="ir.ui.view">
        <field name="name">fetch.waybills.wizard1.form</field>
        <field name="model">fetch.waybills.wizard1</field>
        <field name="arch" type="xml">
            <form string="Fetch Waybills">
                <group>
                    <field name="date1"/>
                    <field name="date2"/>
                </group>
                <footer>
                    <button string="გადმოწერა" type="object" name="fetch_waybills_1" class="oe_highlight" style="color:red"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action for fetch.waybills.wizard1 -->
    <record id="action_fetch_waybills_wizard1" model="ir.actions.act_window">
        <field name="name">Fetch Waybills Wizard1</field>
        <field name="res_model">fetch.waybills.wizard1</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_fetch_waybills_wizard1_form"/>
        <field name="target">new</field>
    </record>

    <!-- list View for Waybill Model with filter on types 1, 4, 5, and 6 -->
    <record id="view_waybill_list_filtered" model="ir.ui.view">
        <field name="name">waybill.list.filtered</field>
        <field name="model">waybill</field>
        <field name="arch" type="xml">
            <list js_class="button_1_list" create="false" string="შესყიდვის დაბრუნება" decoration-success="mdgomareoba == 'korektirebuli'" decoration-warning="mdgomareoba == 'gadatanili'">
                <!-- <header>
                    <button name="action_open_fetch_waybills_wizard1" type="object" string="ზედნადების ჩამოტვირთვა" class="oe_highlight"/>
                </header> -->
                <field name="waybill_id_number"/>
                <field name="waybill_number"/>
                <field name="waybill_type"/>
                <field name="create_date"/>
                <field name="buyer_tin"/>
                <field name="buyer_name"/>
                <field name="seller_name"/>
                <field name="seller_tin"/>
                <field name="start_address"/>
                <field name="transport_cost"/>
                <field name="activate_date"/>
                <field name="full_amount"/>
                <field name="waybill_type"/>
                <field name="mdgomareoba"/>
            </list>
        </field>
    </record>

    <!-- Form View for Waybill Model -->
    <record id="view_waybill_form_filtered" model="ir.ui.view">
        <field name="name">waybill.form.filtered</field>
        <field name="model">waybill</field>
        <field name="arch" type="xml">
            <form string="Waybill">
                <sheet>
                    <group>
                        <group>
                            <field name="waybill_id_number"/>
                            <field name="waybill_number"/>
                            <field name="waybill_type"/>
                            <field name="create_date"/>
                            <field name="buyer_tin"/>
                            <field name="buyer_name"/>
                            <field name="seller_name"/>
                            <field name="seller_tin"/>
                            <field name="start_address"/>
                            <field name="transport_cost"/>
                            <field name="activate_date"/>
                            <field name="full_amount"/>
                        </group>
                        <group>
                            <field name="s_user_id" invisible="1"/>
                            <field name="begin_date" invisible="1"/>
                            <field name="is_confirmed" invisible="1"/>
                            <field name="is_corrected" invisible="1"/>
                            <field name="seller_st" invisible="1"/>
                            <field name="is_med" invisible="1"/>
                            <field name="waybill_comment"/>
                            <field name="end_address"/>
                            <field name="driver_tin"/>
                            <field name="driver_name"/>
                            <field name="car_number"/>
                            <field name="delivery_date"/>
                            <field name="close_date"/>
                            <field name="error_text" invisible="1"/>
                            <field name="product_category_id"/>
                            <field name="stockId1"/>
                            <field name="stock_Name"/>
                            <field name="xarjgat"/>
                            <field name="xarjang"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="w_name"/>
                                    <field name="quantity"/>
                                    <field name="price"/>
                                    <field name="amount"/>
                                    <field name="bar_code"/>
                                    <field name="a_id"/>
                                    <field name="vat_type"/>
                                    <field name="koef"/>
                                    <field name="product_id"/>
                                    <field name="quantity_fact"/>
                                    <field name="unit_id"/>
                                    <field name="unit_txt"/>
                                </list>
                                <form string="Line Details">
                                    <group>
                                        <field name="w_name"/>
                                        <field name="quantity"/>
                                        <field name="price"/>
                                        <field name="amount"/>
                                        <field name="bar_code"/>
                                        <field name="a_id"/>
                                        <field name="vat_type"/>
                                        <field name="product_id"/>
                                        <field name="quantity_fact"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View for Waybill Model -->
    <record id="view_waybill_search_filtered" model="ir.ui.view">
        <field name="name">waybill.search.filtered</field>
        <field name="model">waybill</field>
        <field name="arch" type="xml">
            <search string="Waybill Search">
                <field name="waybill_number"/>
                <field name="buyer_tin"/>
                <field name="create_date"/>
                <field name="waybill_type"/>
            </search>
        </field>
    </record>

    <!-- Action for Filtered Waybill Model -->
    <record id="action_waybill_filtered" model="ir.actions.act_window">
        <field name="name">შესყიდვის დაბრუნება</field>
        <field name="res_model">waybill</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_waybill_list_filtered"/>
        <field name="domain">['|', ('error_text', '=', 'შესყიდვის დაბრუნება'), ('error_text', '=', False)]</field>

    </record>

    <!-- Menu Item for Filtered Waybill Model under Waybill Management -->
    <menuitem id="menu_waybill_filtered" 
              name="შესყიდვის დაბრუნება" 
              parent="menu_waybill_root" 
              action="action_waybill_filtered" 
              sequence="3"/>

    <!-- Access Rules -->
    <record id="waybill_rule_manager" model="ir.rule">
        <field name="name">Waybill Manager Rule</field>
        <field name="model_id" ref="model_waybill"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="waybill_rule_user" model="ir.rule">
        <field name="name">Waybill User Rule</field>
        <field name="model_id" ref="model_waybill"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
