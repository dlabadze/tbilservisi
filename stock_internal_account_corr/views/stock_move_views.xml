<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_move_operations_internal_account_corr" model="ir.ui.view">
        <field name="name">stock.move.operations.internal.account.corr</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_stock_move_operations"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="is_internal_transfer_corr" column_invisible="1"/>
                <field name="move_account_corr_id"
                       string="Debit Correction Account"
                       options="{'no_create': True}"
                       invisible="not is_internal_transfer_corr"
                       optional="hide"/>
                <field name="analytic_distribution_corr"
                       widget="analytic_distribution"
                       groups="analytic.group_analytic_accounting"
                       invisible="not is_internal_transfer_corr"
                       optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
