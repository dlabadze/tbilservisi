<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Add a dedicated "Partner VAT" column to the Partner Ledger report,
        positioned before the Journal column. The column itself will be
        filled only on grouped partner lines by the custom handler.
    -->

    <record id="partner_ledger_report_partner_vat_column" model="account.report.column">
        <field name="name">Partner VAT</field>
        <field name="expression_label">partner_vat</field>
        <!-- Use 'string' figure_type for plain text column -->
        <field name="figure_type">string</field>
        <field name="sortable">False</field>
        <!-- Sequence chosen so the column appears just AFTER the Journal column -->
        <field name="sequence">15</field>
        <field name="report_id" ref="account_reports.partner_ledger_report"/>
    </record>

    <!-- Attach the new column to the existing Partner Ledger report -->
    <record id="account_reports.partner_ledger_report" model="account.report">
        <field name="column_ids" eval="[(4, ref('partner_ledger_extension.partner_ledger_report_partner_vat_column'))]"/>
    </record>

</odoo>
