<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fitpass_import_wizard_form" model="ir.ui.view">
        <field name="name">fitpass.import.wizard.form</field>
        <field name="model">fitpass.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Fitpass Data">
                <group>
                    <group>
                        <field name="excel_file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="start_row"/>
                        <field name="end_row"/>
                    </group>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fitpass_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Fitpass Excel</field>
        <field name="res_model">fitpass.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
