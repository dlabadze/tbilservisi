<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_journal_id_readonly" model="ir.ui.view">
        <field name="name">account.move.form.journal.id.readonly</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='journal_div']/field[@name='journal_id']" position="attributes">
                <attribute name="readonly">state in ('posted', 'cancel')</attribute>
            </xpath>
        </field>
    </record>
</odoo>
