<odoo>
    <record id="view_account_journal_dashboard_kanban_inherit_import" model="ir.ui.view">
        <field name="name">account.journal.dashboard.kanban.import</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="inside">
                <header>
                    <button type="action"
                            name="%(action_bank_import_wizard)d"
                            string="ატვირთე Excel ფაილი"
                            class="btn btn-primary"
                            display="always"
                            icon="fa-upload"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
