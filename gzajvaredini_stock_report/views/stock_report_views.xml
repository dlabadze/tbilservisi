<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Stock Report List View -->
    <record id="view_gza_stock_report_list" model="ir.ui.view">
        <field name="name">gza.stock.report.list</field>
        <field name="model">gza.stock.report</field>
        <field name="arch" type="xml">
            <list string="Stock Report" >
                <field name="product_name" string="პროდუქცია"/>
                <field name="internal_ref" string="პროდუქციის კოდი"/>
                <field name="category_id" string="კატეგორია"/>
                <field name="warehouse_id" string="საწყობი"/>
                <field name="uom_name" string="ერთეული"/>
                <field name="initial_qty" sum="Initial Balance"/>
                <field name="incoming_qty" sum="Incoming"/>
                <field name="outgoing_qty" sum="Outgoing"/>
                <field name="final_qty" sum="Final Balance"/>
                <field name="initial_amount" sum="Initial Balance Amount"/>
                <field name="incoming_amount" sum="Incoming Amount"/>
                <field name="outgoing_amount" sum="Outgoing Amount"/>
                <field name="final_amount" sum="Final Balance Amount"/>
                <field name="date_from" invisible="0"/>
                <field name="date_to" invisible="0"/>
                <button name="action_view_stock_moves"
                        type="object"
                        string="History"
                        class="btn-link"
                        icon="fa-history"/>
            </list>
        </field>
    </record>

    <record id="view_gza_stock_report_list_no_category" model="ir.ui.view">
        <field name="name">gza.stock.report.list.no.category</field>
        <field name="model">gza.stock.report</field>
        <field name="arch" type="xml">
            <list string="Stock Report" >
                <field name="product_name" string="პროდუქცია"/>
                <field name="internal_ref" string="პროდუქციის კოდი"/>
                <field name="warehouse_id" string="საწყობი"/>
                <field name="location_id" string="ლოკაცია"/>
                <field name="uom_name" string="ერთეული"/>
                <field name="initial_qty" sum="Initial Balance"/>
                <field name="incoming_qty" sum="Incoming"/>
                <field name="outgoing_qty" sum="Outgoing"/>
                <field name="final_qty" sum="Final Balance"/>
                <field name="initial_amount" sum="Initial Balance Amount"/>
                <field name="incoming_amount" sum="Incoming Amount"/>
                <field name="outgoing_amount" sum="Outgoing Amount"/>
                <field name="final_amount" sum="Final Balance Amount"/>
                <field name="date_from" invisible="0"/>
                <field name="date_to" invisible="0"/>
                <button name="action_view_stock_moves"
                        type="object"
                        string="History"
                        class="btn-link"
                        icon="fa-history"/>
            </list>
        </field>
    </record>
    
    <!-- Custom Stock Move History List View with From/To -->
    <record id="view_stock_move_history_list" model="ir.ui.view">
        <field name="name">stock.move.history.list</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <list string="Stock Moves History" create="false" edit="false">
                <field name="date"/>
                <field name="reference"/>
                <field name="picking_id"/>
                <field name="product_id"/>
                <field name="location_id" string="From"/>
                <field name="location_dest_id" string="To"/>
                <field name="product_uom_qty" string="Quantity"/>
                <field name="product_uom" string="UoM"/>
                <field name="state"/>
                <field name="picking_type_id" optional="show"/>
            </list>
        </field>
    </record>
    
    <!-- Stock Report Search View with Exact Matching -->
    <record id="view_gza_stock_report_search" model="ir.ui.view">
        <field name="name">gza.stock.report.search</field>
        <field name="model">gza.stock.report</field>
        <field name="arch" type="xml">
            <search string="Stock Report">
                <field name="product_id"/>
                <field name="uom_name"/>
                <field name="warehouse_id"/>
                <field name="initial_qty"/>
                <field name="incoming_qty"/>
                <field name="outgoing_qty"/>
                <field name="final_qty"/>
                <field name="initial_amount"/>
                <field name="incoming_amount"/>
                <field name="outgoing_amount"/>
                <field name="final_amount"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <filter string="With Stock" name="with_stock" domain="[('final_qty', '&gt;', 0)]"/>
                <filter string="Out of Stock" name="out_of_stock" domain="[('final_qty', '&lt;=', 0)]"/>
                <filter string="With Movement" name="with_movement" domain="['|',('incoming_qty','>',0),('outgoing_qty','>',0)]"/>
            </search>
        </field>
    </record>
    
    <!-- Wizard Form View remains the same -->
    <record id="view_gza_stock_report_wizard_form" model="ir.ui.view">
        <field name="name">gza.stock.report.wizard.form</field>
        <field name="model">gza.stock.report.wizard</field>
        <field name="arch" type="xml">
            <form string="რეპორტი საწყობების მიხედვით">
                <group>
                    <group>
                        <field name="date_from" string="საწყისი თარიღი"/>
                        <field name="date_to" string="საბოლოო თარიღი"/>
                    </group>
                    <group>
                        <field name="warehouse_ids" widget="many2many_tags" string="საწყობები"/>
                        <field name="use_category_filter" string="კატეგორიებით გაფილტვრა"/>
                        <field name="category_ids" widget="many2many_tags" string="კატეგორიები"
                            invisible="not use_category_filter"/>
                        <field name="include_internal_transfers"/>
                        <field name="location_filter" string="ლოკაციებით გაფილტვრა"/>
                        <field name="location_ids" widget="many2many_tags" string="ლოკაციები"
                            invisible="not location_filter"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="რეპორტის გენერაცია" type="object" class="btn-primary"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- Actions remain the same, but removed pivot view -->
    <record id="action_gza_stock_report" model="ir.actions.act_window">
        <field name="name">Stock Report</field>
        <field name="res_model">gza.stock.report</field>
        <field name="view_mode">list</field> <!-- Removed pivot from view_mode -->
        <field name="search_view_id" ref="view_gza_stock_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No stock data available.
            </p>
            <p>
                Use the filters to select a date range and warehouses.
            </p>
        </field>
    </record>
    
    <record id="action_gza_stock_report_wizard" model="ir.actions.act_window">
        <field name="name">Stock Report</field>
        <field name="res_model">gza.stock.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    
    <!-- Menu Items remain the same -->
    <menuitem id="menu_gza_stock_report"
              name="Stock Report" 
              parent="stock.menu_warehouse_report" 
              action="action_gza_stock_report_wizard"
              sequence="10"/>
</odoo>