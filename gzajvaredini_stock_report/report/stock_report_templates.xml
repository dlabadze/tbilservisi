<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report action -->
    <record id="action_report_gza_sport_stock_report" model="ir.actions.report">
        <field name="name">Stock Movement Report</field>
        <field name="model">gza.sport.stock.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gza_sport_stock_report.report_stock_movement</field>
        <field name="report_file">gza_sport_stock_report.report_stock_movement</field>
        <field name="binding_model_id" ref="model_gza_sport_stock_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Main report template -->
    <template id="report_stock_movement">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Stock Movement Report</h2>
                    <div class="row mt32 mb32">
                        <div class="col-3">
                            <strong>Date Range:</strong>
                            <p t-esc="context.get('date_from')" t-options='{"widget": "date"}'/>
                            <strong>to</strong>
                            <p t-esc="context.get('date_to')" t-options='{"widget": "date"}'/>
                        </div>
                        <div class="col-3">
                            <strong>Warehouses:</strong>
                            <p t-if="context.get('warehouse_names')">
                                <span t-esc="context.get('warehouse_names')"/>
                            </p>
                            <p t-else="">All Warehouses</p>
                        </div>
                        <div class="col-3">
                            <strong>Categories:</strong>
                            <p t-if="context.get('category_names')">
                                <span t-esc="context.get('category_names')"/>
                            </p>
                            <p t-else="">All Categories</p>
                        </div>
                    </div>

                    <table class="table table-sm o_main_table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Warehouse</th>
                                <th>Location</th>
                                <th class="text-right">Initial Balance</th>
                                <th class="text-right">Incoming</th>
                                <th class="text-right">Outgoing</th>
                                <th class="text-right">Final Balance</th>
                                <th>UoM</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="report_data" t-as="line">
                                <td>
                                    <span t-esc="line['product_name']"/>
                                </td>
                                <td>
                                    <span t-esc="line['warehouse_name']"/>
                                </td>
                                <td>
                                    <span t-esc="line['location_name']"/>
                                </td>
                                <td class="text-right">
                                    <span t-esc="line['initial_qty']" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                                <td class="text-right">
                                    <span t-esc="line['incoming_qty']" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                                <td class="text-right">
                                    <span t-esc="line['outgoing_qty']" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                                <td class="text-right">
                                    <span t-esc="line['final_qty']" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                                <td>
                                    <span t-esc="line['uom_name']"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>