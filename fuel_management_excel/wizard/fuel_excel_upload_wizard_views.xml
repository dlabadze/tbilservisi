<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_fuel_excel_upload_wizard_form" model="ir.ui.view">
		<field name="name">fuel.excel.upload.wizard.form</field>
		<field name="model">fuel.excel.upload.wizard</field>
		<field name="arch" type="xml">
			<form string="ატვირთვა">
				<group>
					<field name="date"/>
					<field name="import_type"/>
					<field name="file_name" invisible="1"/>
					<field name="file_data" filename="file_name"/>
				</group>
				<footer>
					<button name="action_confirm" type="object" string="დადასტურება" class="btn-primary"/>
					<button string="გაუქმება" class="btn-secondary" special="cancel"/>
				</footer>
			</form>
		</field>
	</record>

	<record id="action_fuel_excel_upload_wizard" model="ir.actions.act_window">
		<field name="name">ატვირთვა</field>
		<field name="res_model">fuel.excel.upload.wizard</field>
		<field name="view_mode">form</field>
		<field name="target">new</field>
		<field name="binding_model_id" ref="fuel_management.model_fuel_management"/>
		<field name="binding_type">action</field>
		<field name="binding_view_types">list</field>
	</record>
</odoo>
