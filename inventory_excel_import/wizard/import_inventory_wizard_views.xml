<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="view_inventory_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">inventory.excel.import.wizard.form</field>
        <field name="model">inventory.excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Historical Inventory">
                <sheet>
                    <group>
                        <p class="text-muted" colspan="2">
                            Upload an exported Odoo product list (must contain columns `product_id/id`, `location_id/id`, and `რაოდ`).
                            Select the date you want these quantities and stock moves to reflect in the database.
                        </p>
                        <field name="target_date"/>
                        <field name="file_name" invisible="1"/>
                        <field name="excel_file" filename="file_name" widget="binary"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import_inventory" string="Import and Backdate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_inventory_excel_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Historical Inventory</field>
        <field name="res_model">inventory.excel.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_inventory_excel_import"
              name="Import Historical Inventory"
              parent="stock.menu_stock_inventory_control"
              sequence="100"
              action="action_inventory_excel_import_wizard"/>

</odoo>
