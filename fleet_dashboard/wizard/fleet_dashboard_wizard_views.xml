<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fleet_dashboard_wizard_form" model="ir.ui.view">
        <field name="name">fleet.dashboard.wizard.form</field>
        <field name="model">fleet.dashboard.wizard</field>
        <field name="arch" type="xml">
            <form string="ავტოპარკის ანალიტიკა">
                <sheet>
                    <div class="oe_title">
                        <h1>ავტოპარკის სერვისის ანალიტიკა</h1>
                        <p class="text-muted">
                            აირჩიე რეპორტი, პერიოდი და სასურველი ფილტრები. დააჭირე
                            <b>რეპორტის ჩვენება</b> შედეგების სანახავად.
                        </p>
                    </div>

                    <group>
                        <group string="რის ჩვენება">
                            <field name="report_type"/>
                            <field name="top_n" widget="radio" options="{'horizontal': true}"/>
                            <field name="view_mode" widget="radio" options="{'horizontal': true}"/>
                        </group>
                        <group string="პერიოდი">
                            <field name="period"/>
                            <field name="date_from"
                                   readonly="period != 'custom'"
                                   required="period == 'custom'"/>
                            <field name="date_to"
                                   readonly="period != 'custom'"
                                   required="period == 'custom'"/>
                        </group>
                    </group>

                    <group string="ფილტრები (სასურველი — დატოვე ცარიელი ყველასთვის)">
                        <group>
                            <field name="vehicle_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="product_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="workshop_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="vendor_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="service_type_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_open_report"
                            type="object"
                            string="რეპორტის ჩვენება"
                            class="btn-primary"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fleet_dashboard_wizard" model="ir.actions.act_window">
        <field name="name">ავტოპარკის სერვისის ანალიტიკა</field>
        <field name="res_model">fleet.dashboard.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Pre-set wizard launchers for each report type -->
    <record id="action_wizard_most_serviced" model="ir.actions.act_window">
        <field name="name">ყველაზე ხშირად მომსახურებული ავტომობილები</field>
        <field name="res_model">fleet.dashboard.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'most_serviced'}</field>
    </record>

    <record id="action_wizard_most_expensive" model="ir.actions.act_window">
        <field name="name">ყველაზე ძვირადღირებული ავტომობილები</field>
        <field name="res_model">fleet.dashboard.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'most_expensive'}</field>
    </record>

    <record id="action_wizard_top_parts" model="ir.actions.act_window">
        <field name="name">ყველაზე ხშირად გამოყენებული ნაწილები</field>
        <field name="res_model">fleet.dashboard.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'top_parts'}</field>
    </record>

    <record id="action_wizard_expensive_parts" model="ir.actions.act_window">
        <field name="name">ყველაზე ძვირადღირებული ნაწილები</field>
        <field name="res_model">fleet.dashboard.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'top_expensive_parts'}</field>
    </record>

    <record id="action_wizard_by_workshop" model="ir.actions.act_window">
        <field name="name">საამქროების მიხედვით</field>
        <field name="res_model">fleet.dashboard.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'by_workshop'}</field>
    </record>

    <record id="action_wizard_by_vendor" model="ir.actions.act_window">
        <field name="name">მომწოდებლების მიხედვით</field>
        <field name="res_model">fleet.dashboard.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'by_vendor'}</field>
    </record>

</odoo>
