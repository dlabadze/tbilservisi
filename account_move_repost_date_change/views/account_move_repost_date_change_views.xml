<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_repost_date_change_wizard_form" model="ir.ui.view">
        <field name="name">account.move.repost.date.change.wizard.form</field>
        <field name="model">account.move.repost.date.change.wizard</field>
        <field name="arch" type="xml">
            <form string="Repost With New Date">
                <group>
                    <field name="date"/>
                    <field name="renumber_mode"/>
                    <field name="allow_unreconcile"/>
                </group>
                <div class="alert alert-warning" role="alert">
                    Posted entries will be reset to draft, updated with the selected accounting date,
                    and posted again. If the old number does not match the new date, Odoo will assign
                    a new number for the selected period. Reconciled entries are blocked unless
                    reconciliation removal is explicitly allowed.
                </div>
                <footer>
                    <button name="action_repost_with_new_date" string="დადასტურება" type="object" class="btn-primary"/>
                    <button string="გაუქმება" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_move_repost_date_change_wizard" model="ir.actions.act_window">
        <field name="name">თარიღით თავიდან დაპოსტვა</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.move.repost.date.change.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_account_move_repost_date_change_wizard_form"/>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list,form</field>
        <field name="groups_id" eval="[(4, ref('account.group_account_invoice'))]"/>
    </record>
</odoo>
