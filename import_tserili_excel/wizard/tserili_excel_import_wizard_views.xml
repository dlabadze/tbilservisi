<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tserili_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">tserili.excel.import.wizard.form</field>
        <field name="model">tserili.excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Tserili Excel Import">
                <sheet>
                    <group>
                        <field name="excel_field" filename="filename" widget="binary"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import_excel" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_tserili_excel_import_wizard" model="ir.actions.act_window">
        <field name="name">Tserili Excel Import</field>
        <field name="res_model">tserili.excel.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
