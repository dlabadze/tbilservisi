<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_initial_balance_wizard_form" model="ir.ui.view">
        <field name="name">initial.balance.wizard.form</field>
        <field name="model">initial.balance.wizard</field>
        <field name="arch" type="xml">
            <form string="საწყისი ნაშთები">
                <sheet>
                    <group>
                        <field name="excel_file" filename="excel_filename"/>
                        <field name="excel_filename" invisible="1"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <p><strong>Note:</strong> The journal entry will be created with:</p>
                        <ul>
                            <li><strong>Date:</strong> December 31, 2025</li>
                            <li><strong>Journal:</strong> Opening Entries Journal</li>
                        </ul>
                    </div>
                    <notebook>
                        <page string="Instructions">
                            <group>
                                <div class="alert alert-info" role="alert">
                                    <h4>Excel File Format:</h4>
                                    <ul>
                                        <li><strong>Column A:</strong> Account Code</li>
                                        <li><strong>Column B:</strong> Identification ID (VAT)</li>
                                        <li><strong>Column C:</strong> Partner Name (used if VAT not found)</li>
                                        <li><strong>Column D:</strong> Amount</li>
                                    </ul>
                                    <p><strong>Rules:</strong></p>
                                    <ul>
                                        <li>Data starts from row 2 (row 1 is header)</li>
                                        <li>Accounts starting with "14" → Debit</li>
                                        <li>Accounts starting with "9" → Credit</li>
                                        <li>If Identification ID contains ".", only the left part is used</li>
                                        <li>Partners are searched by VAT first, then by name if not found</li>
                                    </ul>
                                </div>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_import_initial_balance" 
                            string="Import" 
                            type="object" 
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_initial_balance_wizard" model="ir.actions.act_window">
        <field name="name">საწყისი ნაშთები</field>
        <field name="res_model">initial.balance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_invoice_tree_inherit_kveba" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.kveba</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account_kveba.view_invoice_tree_inherit_kveba"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_initial_balance_wizard)d" 
                        string="საწყისი ნაშთები" 
                        type="action" 
                        class="btn-primary"
                        display="always"/>
            </xpath>
        </field>
    </record>
</odoo>

