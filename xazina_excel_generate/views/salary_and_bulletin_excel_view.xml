<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_salary_and_bulletin_excel_form" model="ir.ui.view">
        <field name="name">salary.and.bulletin.excel.form</field>
        <field name="model">salary.and.bulletin.excel</field>
        <field name="arch" type="xml">
            <form string="ხელფასის და ბიულეტენი">
                <group>
                    <field name="date"/>
                </group>
                <footer>
                    <button name="action_generate_excel"
                            string="ექსელის გენერაცია"
                            type="object"
                            class="btn-primary"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_salary_and_bulletin_excel" model="ir.actions.act_window">
        <field name="name">ხელფასის და ბიულეტენი</field>
        <field name="res_model">salary.and.bulletin.excel</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
