<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_xazina_dakavebebi_excel_form" model="ir.ui.view">
        <field name="name">xazina.dakavebebi.excel.form</field>
        <field name="model">xazina.dakavebebi.excel</field>
        <field name="arch" type="xml">
            <form string="ხაზინა-დაკავებები">
                <group>
                    <field name="date"/>
                </group>
                <footer>
                    <button name="action_generate_excel"
                            string="ექსელის გენერაცია"
                            type="object"
                            class="btn-primary"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_xazina_dakavebebi_excel" model="ir.actions.act_window">
        <field name="name">ხაზინა-დაკავებები</field>
        <field name="res_model">xazina.dakavebebi.excel</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
