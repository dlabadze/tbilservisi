<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the view_move_line_tree view from account module -->
    <record id="view_move_line_tree_inherit" model="ir.ui.view">
        <field name="name">account.move.line.tree.inherit</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <field name="date" position="after">
                <field name="get_invoice_id_helper" string="ფაქტური ნომერი" optional="show"/>
                <field name="move_id_comment" string="კომენტარი" optional="show"/>
            </field>
        </field>
    </record>
</odoo>

