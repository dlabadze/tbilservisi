<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="view_account_asset_form_declining_nbv" model="ir.ui.view">
			<field name="name">account.asset.form.declining_nbv</field>
			<field name="model">account.asset</field>
			<field name="inherit_id" ref="account_asset.view_account_asset_form"/>
			<field name="arch" type="xml">
				<xpath expr="//field[@name='method_progress_factor']" position="attributes">
					<attribute name="invisible">method not in ('degressive', 'declining', 'degressive_then_linear', 'declining_then_linear', 'declining_nbv')</attribute>
				</xpath>
			</field>
		</record>
	</data>
</odoo>
