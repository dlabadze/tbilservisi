<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_initial_inventory_import_wizard_form" model="ir.ui.view">
        <field name="name">initial.inventory.import.wizard.form</field>
        <field name="model">initial.inventory.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Initial Inventory">
                <group>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="date"/>
                    <field name="inventory_name"/>
                    <field name="quantity_mode"/>
                    <field name="new_product_category_id"/>
                    <field name="new_product_uom_id"/>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <div class="alert alert-info" role="alert">
                    XLSX columns (in this order): A=Location external ID, B=default_code (SKU),
                    C=Product name, D=Quantity, E=Starting Average Price.
                    Products are matched by default_code. If a default_code is not found, a new product is
                    created using the chosen Category and Unit of Measure. The starting average price sets
                    the product cost used to value the opening stock.
                </div>
                <footer>
                    <button name="action_import_initial_inventory" string="დადასტურება" type="object" class="btn-primary"/>
                    <button string="გაუქმება" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_initial_inventory_import_wizard" model="ir.actions.act_window">
        <field name="name">საწყისი ნაშთის ატვირთვა</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">initial.inventory.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_initial_inventory_import_wizard_form"/>
        <field name="target">new</field>
        <field name="groups_id" eval="[(4, ref('stock.group_stock_manager'))]"/>
    </record>

    <menuitem
        id="menu_initial_inventory_import_wizard"
        name="საწყისი ნაშთის ატვირთვა"
        parent="stock.menu_stock_adjustments"
        action="action_initial_inventory_import_wizard"
        groups="stock.group_stock_manager"
        sequence="11"/>
</odoo>
