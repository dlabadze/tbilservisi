<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ===================================================== -->
    <!--  Import Wizard View -->
    <!-- ===================================================== -->
    <record id="view_zeganakveturi_import_wizard_form" model="ir.ui.view">
        <field name="name">zeganakveturi.import.wizard.form</field>
        <field name="model">zeganakveturi.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Excel იმპორტი" version="7.0">
                <group>
                    <field name="entry_type"/>
                    <field name="date"/>
                    <field name="comment"/>
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>

                <group>
                    <field name="start_row"/>
                    <field name="end_row"/>
                </group>
                <footer>
                    <button name="action_import"
                            string="იმპორტი"
                            type="object"
                            class="btn-primary"/>
                    <button string="გაუქმება"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ===================================================== -->
    <!--  Wizard Action -->
    <!-- ===================================================== -->
    <record id="action_zeganakveturi_import_wizard" model="ir.actions.act_window">
        <field name="name">Excel იმპორტი</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">zeganakveturi.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ===================================================== -->
    <!--  Menu Button Under "ზეგანაკვეთური საათები" -->
    <!-- ===================================================== -->
    <menuitem id="menu_zeganakveturi_import"
              name="Excel იმპორტი"
              parent="menu_zeganakveturi_master"
              action="action_zeganakveturi_import_wizard"
              sequence="20"/>

</odoo>
