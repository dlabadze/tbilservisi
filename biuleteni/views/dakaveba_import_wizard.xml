<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_dakaveba_import_wizard" model="ir.actions.act_window">
        <field name="name">დაკავების იმპორტი</field>
        <field name="res_model">dakaveba.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_dakaveba_import_wizard_form" model="ir.ui.view">
        <field name="name">dakaveba.import.wizard.form</field>
        <field name="model">dakaveba.import.wizard</field>
        <field name="arch" type="xml">
            <form string="დაკავების იმპორტი">
                <group>
                    <field name="file_data"/>
                    <field name="file_name"/>
                    <field name="date"/>
                    <field name="department_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="comment"/>
                    <field name="start_row"/>
                    <field name="end_row"/>
                </group>

                <footer>
                    <button name="action_import" string="იმპორტი" type="object" class="btn-primary"/>
                    <button string="გაუქმება" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
