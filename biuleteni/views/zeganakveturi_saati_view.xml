<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ====================== FORM VIEW ====================== -->
    <record id="view_zeganakveturi_saati_form" model="ir.ui.view">
        <field name="name">zeganakveturi.saati.form</field>
        <field name="model">zeganakveturi_saati</field>
        <field name="arch" type="xml">
            <form string="დანამატები">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,validated"/>

                    <button name="action_validate"
                            string="დადასტურება"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'validated'"/>

                    <button name="action_reset_draft"
                            string="დრაფტად დაბრუნება"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'draft'"/>
                </header>

                <sheet>
                    <group>
                        <field name="entry_type"/>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="comment"/>
                        <field name="total_amount" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="დეტალები" name="zeganakveturi_saati_lines">
                            <field name="zeganakveturi_saati_line_ids">
                                <list editable="bottom">
                                    <field name="entry_type" column_invisible="1"/>
                                    <field name="identification_id" optional="show"/>
                                    <field name="employee_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="parent_department_id" optional="show" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="department_id" optional="show" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="job_id" optional="show" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="worked_hours"
                                           column_invisible="parent.entry_type != 'zeganakveturi_saati'"/>
                                    <field name="hourly_rate"/>
                                    <field name="amount" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ====================== TREE VIEW ====================== -->
    <record id="view_zeganakveturi_saati_list" model="ir.ui.view">
        <field name="name">zeganakveturi.saati.list</field>
        <field name="model">zeganakveturi_saati</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'validated'">
                <field name="entry_type"/>
                <field name="name"/>
                <field name="date"/>
                <field name="total_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>


    <!-- ====================== SEARCH VIEW ====================== -->
    <record id="view_zeganakveturi_saati_search" model="ir.ui.view">
        <field name="name">zeganakveturi.saati.search</field>
        <field name="model">zeganakveturi_saati</field>
        <field name="arch" type="xml">
            <search string="ძებნა">
                <field name="entry_type"/>
                <field name="name"/>
                <field name="date"/>
                <field name="total_amount"/>

                <separator/>
                <filter name="filter_draft" string="დრაფტი" domain="[('state','=','draft')]"/>
                <filter name="filter_validated" string="დადასტურებული" domain="[('state','=','validated')]"/>

                <group expand="0" string="დაჯგუფება">
                    <filter string="თარიღით" name="group_by_date" context="{'group_by':'date:month'}"/>
                    <filter string="სტატუსით" name="group_by_state" context="{'group_by':'state'}"/>
                    <filter string="ტიპით" name="group_by_entry_type" context="{'group_by':'entry_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ====================== ACTION ====================== -->
    <record id="action_zeganakveturi_saati" model="ir.actions.act_window">
        <field name="name">დანამატები</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">zeganakveturi_saati</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_zeganakveturi_saati_search"/>
        <field name="context">{'biuleteni_dept_name': True}</field>
    </record>

    <!-- ====================== MENU ====================== -->
    

    <menuitem id="menu_zeganakveturi_master"
          name="დანამატები"
          parent="menu_biuleteni_root"
          sequence="30"/>

    <menuitem id="menu_zeganakveturi_list"
          name="ჩანაწერები"
          parent="menu_zeganakveturi_master"
          action="action_zeganakveturi_saati"
          sequence="10"/>          

</odoo>
