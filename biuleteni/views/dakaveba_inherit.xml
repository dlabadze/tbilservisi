<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- IMPORT WIZARD ACTION                                  -->
    <!-- ===================================================== -->
    <record id="action_dakaveba_import_wizard" model="ir.actions.act_window">
        <field name="name">დაკავება იმპორტი</field>
        <field name="res_model">dakaveba.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


    <!-- ===================================================== -->
    <!-- IMPORT WIZARD FORM VIEW                               -->
    <!-- ===================================================== -->
    <record id="view_dakaveba_import_wizard_form" model="ir.ui.view">
        <field name="name">dakaveba.import.wizard.form</field>
        <field name="model">dakaveba.import.wizard</field>

        <field name="arch" type="xml">
            <form string="დაკავება იმპორტი">
                <group>
                    <field name="file_data"/>
                    <field name="file_name"/>
                    <field name="date"/>
                    <field name="department_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="comment"/>
                    <field name="start_row"/>
                    <field name="end_row"/>
                </group>

                <footer>
                    <button name="action_import"
                            string="იმპორტი"
                            type="object"
                            class="btn-primary"/>
                    <button string="გაუქმება" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


    <!-- ===================================================== -->
    <!-- ADD "IMPORT" TO ACTION DROPDOWN IN SETTINGS MENU      -->
    <!-- ===================================================== -->
    <record id="ir_action_dakaveba_import_in_actions" model="ir.values">
        <field name="name">Import Dakaveba</field>
        <field name="model_id" ref="model_dakaveba"/>
        <field name="key">action</field>
        <field name="value" eval="'ir.actions.act_window,' + str(ref('action_dakaveba_import_wizard'))"/>
    </record>

</odoo>
