<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_update_contract_department_wizard_form" model="ir.ui.view">
        <field name="name">update.contract.department.wizard.form</field>
        <field name="model">update.contract.department.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Contract Department">
                <group>
                    <field name="department_id" required="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
