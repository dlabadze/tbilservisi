<odoo>
    <record id="view_product_template_form_inherit_auto_code" model="ir.ui.view">
        <field name="name">product.template.form.auto.code</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="default_code" readonly="1"/>
            </field>
        </field>
    </record>

    <record id="product_template_only_form_view_inherit" model="ir.ui.view">
        <field name="name">product.template.only.form.view.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='volume']" position="after">
                <field name="min_amount"/>
            </xpath>
        </field>
    </record>
</odoo>
