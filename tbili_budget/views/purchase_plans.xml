    <record id="view_purchase_requisition_form_inherit_extended" model="ir.ui.view">
        <field name="name">purchase.requisition.form.inherit.extended</field>
        <field name="model">purchase.requisition</field>
        <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_form"/>
        <field name="arch" type="xml">
            <group position="after">
                <group>
                    <group string="თარიღები">
                        <field name="registration_year"/>
                        <field name="contract_registration_date"/>
                        <field name="effective_date"/>
                        <field name="delivery_date"/>
                        <field name="contract_end_date"/>
                        <field name="payment_due_date"/>
                    </group>
                    <group string="ზოგადი ინფორმაცია">
                        <field name="purchase_method"/>
                        <field name="purchase_basis"/>
                        <field name="basis"/>
                        <field name="contract_number"/>
                        <field name="spa_number"/>
                        <field name="cmr_number"/>
                        <field name="cpv_code"/>
                        <field name="budget_article"/>
                    </group>
                </group>
                <group>
                    <group string="მომწოდებელი">
                        <field name="supplier"/>
                        <field name="supplier_id_code"/>
                    </group>
                    <group string="ფინანსური ინფორმაცია">
                        <field name="exchange_rate"/>
                        <field name="percentage"/>
                        <field name="contract_amount"/>
                        <field name="requested_amount"/>
                        <field name="receipt_delivery_amount"/>
                        <field name="paid_amount"/>
                        <field name="penalty_amount"/>
                        <field name="remaining_amount"/>
                    </group>
                </group>
                <group>
                    <group string="სტატუსი და ტიპი">
                        <field name="delivery_type"/>
                        <field name="vat_included"/>
                        <field name="currency_type"/>
                        <field name="currency_rate"/>
                        <field name="contract_status"/>
                    </group>
                    <group string="შენიშვნები">
                        <field name="notes"/>
                    </group>
                </group>
            </group>
        </field>
    </record>

    <!-- Add Purchase Plan and Budget fields to Purchase Order Lines -->
    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.budget</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Add fields to order line form view -->
            <xpath expr="//field[@name='order_line']/form//field[@name='taxes_id']" position="after">
                <field name="purchase_plan_id"/>
                <field name="purchase_plan_line_id" domain="[('plan_id', '=', purchase_plan_id)]"/>
                <field name="budget_analytic_id" domain="[('date_to', '>=', context_today().strftime('%Y-%m-%d'))]"/>
                <field name="available_budget_line_ids" invisible="1"/>
                <field name="budget_line_id" domain="[('id', 'in', available_budget_line_ids)]"/>
                <field name="budget_line_account_id"/>
            </xpath>

            <!-- Add fields to order line list view -->
            <xpath expr="//field[@name='order_line']/list//field[@name='taxes_id']" position="after">
                <field name="purchase_plan_id" optional="show"/>
                <field name="purchase_plan_line_id" optional="show"/>
                <field name="budget_analytic_id" optional="show"/>
                <field name="budget_line_id" optional="show"/>
                <field name="budget_line_account_id" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
   