        <record id="view_purchase_plan_line_form" model="ir.ui.view">
        <field name="name">purchase.plan.line.form</field>
        <field name="model">purchase.plan.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="cpv_id"/>
                            <field name="cpv_name" readonly="1"/>
                            <field name="funding_source"/>
                            <field name="purchase_method_id"/>
                            <field name="purchase_reason_id" domain="[('id', 'in', allowed_reason_ids)]"/>
                            <field name="allowed_reason_ids" invisible="1"/>
                            <field name="vadebi"/>
                            <field name="pricekurant"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                        <group>
                            <field name="pu_st_am"/>
                            <field name="pu_ac_am"/>
                            <field name="pu_diff"/>
                            <field name="pcon_am"/>
                            <field name="pc_re_am"/>
                            <field name="paim_am"/>
                            <field name="pa_re_am"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Budget Information">
                            <group>
                                <field name="budget_cpv_id"/>
                                <field name="change_id"/>
                                <field name="budget_lines_allocated"/>
                                <field name="remaining_to_allocate"/>
                            </group>
                        </page>
                        
                        <page string="Purchase Requisition Lines">
                            <field name="requisition_line_ids">
                                <list>
                                    <field name="requisition_id"/>
                                    <field name="contract_number"/>
                                    <field name="product_id"/>
                                    <field name="product_qty"/>
                                    <field name="price_unit"/>
                                    <field name="line_total"/>
                                    <field name="budget_line_id"/>
                                    <field name="selected_plan_name"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Payment Plan Lines">
                            <field name="payment_plan_line_ids">
                                <list>
                                    <field name="payment_id"/>
                                    <field name="purchase_plan_id"/>
                                    <field name="cpv_id"/>
                                    <field name="cpv_name"/>
                                    <field name="pu_ac_am"/>
                                    <field name="pcon_am"/>
                                    <field name="pa_re_am"/>
                                    <field name="amount"/>
                                    <field name="currency_id"/>
                                </list>
                            </field>
                        </page>

                        <page string="Purchase Orders">
                            <field name="purchase_order_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="date_order"/>
                                    <field name="amount_total"/>
                                    <field name="state"/>
                                    <field name="requisition_id"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_budget_cpv_list" model="ir.ui.view">
        <field name="name">budget.cpv.list</field>
        <field name="model">budget.cpv</field>
        <field name="arch" type="xml">
            <list>
                <field name="custom_id"/>
                <field name="name"/>
                <field name="cpv_name"/>
                <field name="cpv_code"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <record id="view_budget_cpv_form" model="ir.ui.view">
        <field name="name">budget.cpv.form</field>
        <field name="model">budget.cpv</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="custom_id"/>
                        <field name="name"/>
                        <field name="cpv_name"/>
                        <field name="cpv_code"/>
                        <field name="currency_id"/>
                        <field name="amount"/>
                        <field name="total_line_amounts"/>
                        <field name="remaining_amount"/>
                    </group>
                    <notebook>
                        <page string="ბიუჯეტის ხაზები">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="budget_line_id"
                                        domain="[('budget_analytic_id.state', '=', 'confirmed')]"/>
                                    <field name="selected_plan_name"/>
                                    <field name="pu_re_am"/>
                                    <field name="budget_amount"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_purchase_plan_changes_list" model="ir.ui.view">
        <field name="name">purchase.plan.changes.list</field>
        <field name="model">purchase.plan.changes</field>
        <field name="arch" type="xml">
            <list>
                <field name="custom_id"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_plan_changes_form" model="ir.ui.view">
        <field name="name">purchase.plan.changes.form</field>
        <field name="model">purchase.plan.changes</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="custom_id"/>
                        <field name="name"/>
                        <field name="cpv_name"/>
                        <field name="cpv_code"/>
                        <field name="amount"/>
                        <field name="plan_id"/>
                        <field name="purchase_method_id"/>
                        <field name="purchase_reason_id"/>
                        <field name="currency_id" invisible="0"/>
                    </group>
                    <notebook>
                        <page string="ცვლილებების ხაზები">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_purchase_plan_changes_line_list" model="ir.ui.view">
        <field name="name">purchase.plan.changes.line.list</field>
        <field name="model">purchase.plan.changes.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="amount"/>
                <field name="comment"/>
                <field name="currency_id"/>
            </list>
        </field>
    </record>
    <record id="view_purchase_requisition_form_inherit" model="ir.ui.view">
        <field name="name">purchase.requisition.form.inherit</field>
        <field name="model">purchase.requisition</field>
        <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']/form/group" position="inside">
                <field name="total_amount"/>
                <field name="currency"/>
                <field name="value_in_currency"/>
                <field name="supplied_amount"/>
                <field name="remaining_quantity"/>
                <field name="remaining_amount"/>
                <field name="purchase_plan_id"/>
                <field name="purchase_plan_line_id"
                       domain="[('plan_id', '=', purchase_plan_id)]"/>
                <field name="budget_analytic_id"
                       domain="[('date_to', '>=', context_today().strftime('%Y-%m-%d')), ('state', '=', 'confirmed')]"/>
                <field name="budget_line_id"
                       domain="[('id', 'in', available_budget_line_ids), ('budget_analytic_id.state', '=', 'confirmed')]"/>
                <field name="available_budget_line_ids" invisible="0"/>
                <field name="selected_plan_name"/>
            </xpath>
            <xpath expr="//field[@name='line_ids']/list" position="inside">
                <field name="total_amount"/>
                <field name="currency"/>
                <field name="value_in_currency"/>
                <field name="supplied_amount"/>
                <field name="remaining_quantity"/>
                <field name="remaining_amount"/>
                <field name="purchase_plan_id"/>
                <field name="purchase_plan_line_id"
                       domain="[('plan_id', '=', purchase_plan_id)]"/>
                <field name="budget_analytic_id"
                       domain="[('date_to', '>=', context_today().strftime('%Y-%m-%d')), ('state', '=', 'confirmed')]"/>
                <field name="budget_line_id"
                       domain="[('id', 'in', available_budget_line_ids), ('budget_analytic_id.state', '=', 'confirmed')]"/>
                <field name="available_budget_line_ids" invisible="0"/>
                <field name="selected_plan_name"/>
            </xpath>
        </field>
    </record>



    <record id="view_account_payment_form_inherited" model="ir.ui.view">
        <field name="name">account.payment.form.inherited</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Payment Lines">
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="budget_analytic_id"
                                   domain="[('state', '=', 'confirmed')]"/>
                            <field name="budget_line_id"
                                   domain="[('budget_analytic_id', '=', budget_analytic_id),
                                          ('budget_analytic_id.state', '=', 'confirmed')]"/>
                            <field name="paim_am"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
                <page string="Purchase Plan Lines">
                    <field name="purchase_plan_line_ids">
                        <list editable="bottom">
                            <field name="purchase_plan_id"/>
                            <field name="purchase_plan_line_id"
                                   domain="[('plan_id', '=', purchase_plan_id)]"/>
                            <field name="cpv_id"/>
                            <field name="cpv_name"/>
                            <field name="pu_ac_am"/>
                            <field name="pcon_am"/>
                            <field name="currency_id"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

    <record id="action_purchase_plan_changes_line" model="ir.actions.act_window">
