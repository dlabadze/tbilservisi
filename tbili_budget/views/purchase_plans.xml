<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_plan_list" model="ir.ui.view">
        <field name="name">purchase.plan.list</field>
        <field name="model">purchase.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_plan_form" model="ir.ui.view">
        <field name="name">purchase.plan.form</field>
        <field name="model">purchase.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="დასახელება..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="currency_id" invisible="0"/>
                    </group>
                    <notebook>
                        <page string="Purchase Plan Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <button name="action_view_purchase_plan_line_new"
                                        type="object"
                                        string="Open"
                                        icon="fa-eye"
                                        className="btn-secondary"/>
                                    <field name="cpv_id"/>
                                    <field name="budget_cpv_id"/>
                                    <field name="change_id"/>
                                    <field name="cpv_name"/>
                                    <field name="funding_source"/>
                                    <field name="purchase_method_id"/>
                                    <field name="purchase_reason_id"
                                        domain="[('id', 'in', allowed_reason_ids)]"/>
                                    <field name="allowed_reason_ids" column_invisible="1"/>
                                    <field name="vadebi"/>
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                    <field name="purchase_method_code"/>
                                    <!-- <field name="pricekurant" invisible="purchase_method_code not in ['6', '7']"/> -->
                                    <field name="pricekurant" column_invisible="1"/>
                                    <field name="pu_st_am" sum="Total Initial Value"/>
                                    <field name="pu_ac_am" sum="Total Current Value"/>
                                    <field name="pu_diff" sum="Total Difference"/>
                                    <field name="pcon_am" sum="Total Contract Amount"/>
                                    <field name="pc_re_am" sum="Total Remaining by Contract"/>
                                    <field name="paim_am" sum="Total Paid Amount"/>
                                    <field name="pa_re_am" sum="Total Remaining Resource"/>
                                    <field name="currency_id"/>
                                    <field name="budget_lines_allocated" sum="Total Allocated Amount"/>
                                    <field name="remaining_to_allocate" sum="Total Remaining to Allocate"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>  
