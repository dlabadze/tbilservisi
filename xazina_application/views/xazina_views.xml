<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_xazina_list_income" model="ir.ui.view">
        <field name="name">xazina.list.income</field>
        <field name="model">xazina</field>
        <field name="arch" type="xml">
            <list string="Xazina">
                <header>
                    <button name="action_open_xazina_income_import_wizard"
                    type="object"
                    string="შემოსავლების ექსელის ატვირთვა"
                    display="always"/>
                    <button name="action_open_create_gatareba_wizard"
                    type="object"
                    string="გატარებების შექმნა"
                    class="btn-primary"
                    display="always"/>
                </header>
                <field name="xazina_type" column_invisible="1"/>
                <field name="state" widget="badge" decoration-success="state == 'validated'" decoration-muted="state == 'draft'"/>
                <field name="date"/>
                <field name="year"/>
                <field name="request_number"/>
                <field name="commintment_number"/>
                <field name="finance_source"/>
                <field name="commintment_foundation"/>
                <field name="note_1"/>
                <field name="note_2"/>
                <field name="note_3"/>
                <field name="payment_foundation"/>
                <field name="payment_form"/>
                <field name="analytic_account_id"/>
                <field name="amount_in_gel"/>
                <field name="reciever_name"/>
                <field name="reciever_inn"/>
                <field name="reciever_bank_code"/>
                <field name="reciever_bank_name"/>
                <field name="reciever_account"/>
                <field name="sabiujeto_shemosavlis_saxazino_kodi"/>
                <field name="payment_purpose"/>
                <field name="expense_subtype"/>
                <field name="saxazino_kodi"/>
            </list>
        </field>
    </record>

    <record id="view_xazina_list_payment" model="ir.ui.view">
        <field name="name">xazina.list.payment</field>
        <field name="model">xazina</field>
        <field name="arch" type="xml">
            <list string="Xazina">
                <header>
                    <button name="action_open_xazina_payment_import_wizard" 
                    type="object" 
                    string="გადარიცხვების ექსელის ატვირთვა"
                    display="always"/>
                    <button name="action_open_create_gatareba_wizard"
                    type="object"
                    string="გატარებების შექმნა"
                    class="btn-primary"
                    display="always"/>
                </header>
                <field name="xazina_type" column_invisible="1"/>
                <field name="state" widget="badge" decoration-success="state == 'validated'" decoration-muted="state == 'draft'"/>
                <field name="date"/>
                <field name="year"/>
                <field name="request_number"/>
                <field name="commintment_number"/>
                <field name="finance_source"/>
                <field name="commintment_foundation"/>
                <field name="note_1"/>
                <field name="note_2"/>
                <field name="note_3"/>
                <field name="payment_foundation"/>
                <field name="payment_form"/>
                <field name="analytic_account_id"/>
                <field name="amount_in_gel"/>
                <field name="reciever_name"/>
                <field name="reciever_inn"/>
                <field name="reciever_bank_code"/>
                <field name="reciever_bank_name"/>
                <field name="reciever_account"/>
                <field name="sabiujeto_shemosavlis_saxazino_kodi"/>
                <field name="payment_purpose"/>
                <field name="expense_subtype"/>
                <field name="saxazino_kodi"/>
            </list>
        </field>
    </record>

    <record id="view_xazina_form" model="ir.ui.view">
        <field name="name">xazina.form</field>
        <field name="model">xazina</field>
        <field name="arch" type="xml">
            <form string="Xazina">
                <header>
                    <button name="action_return_to_draft"
                        type="object"
                        string="Return to Draft"
                        class="btn-secondary"
                        invisible="state != 'validated'"/>
                    <field name="state" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bank_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-university"
                            invisible="bank_line_count == 0">
                            <field name="bank_line_count" widget="statinfo" string="საბანკო ჩანაწერები"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="year"/>
                            <field name="analytic_account_id"/>
                            <field name="amount_in_gel"/>
                        </group>
                        <group>
                            <field name="request_number"/>
                            <field name="commintment_number"/>
                            <field name="finance_source"/>
                            <field name="commintment_foundation"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Receiver">
                            <group>
                                <field name="reciever_name"/>
                                <field name="reciever_inn"/>
                                <field name="reciever_bank_code"/>
                                <field name="reciever_bank_name"/>
                                <field name="reciever_account"/>
                            </group>
                        </page>
                        <page string="Payment">
                            <group>
                                <field name="payment_foundation"/>
                                <field name="payment_form"/>
                                <field name="payment_purpose"/>
                                <field name="expense_subtype"/>
                                <field name="saxazino_kodi"/>
                                <field name="sabiujeto_shemosavlis_saxazino_kodi"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <group>
                                <field name="note_1"/>
                                <field name="note_2"/>
                                <field name="note_3"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_xazina" model="ir.actions.act_window">
        <field name="name">Xazina</field>
        <field name="res_model">xazina</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_xazina_income" model="ir.actions.act_window">
        <field name="name">შემოსავლები</field>
        <field name="res_model">xazina</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('xazina_type', '=', 'შემოსავლები')]</field>
        <field name="context">{'default_xazina_type': 'შემოსავლები'}</field>
        <field name="view_id" ref="view_xazina_list_income"/>
    </record>

    <record id="action_xazina_payment" model="ir.actions.act_window">
        <field name="name">გადარიცხვები</field>
        <field name="res_model">xazina</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('xazina_type', '=', 'გადარიცხვები')]</field>
        <field name="context">{'default_xazina_type': 'გადარიცხვები'}</field>
        <field name="view_id" ref="view_xazina_list_payment"/>
    </record>

    <menuitem id="menu_xazina_root" name="ხაზინა" sequence="60"/>
    <menuitem id="menu_xazina_income" name="შემოსავლები" parent="menu_xazina_root" action="action_xazina_income" sequence="10"/>
    <menuitem id="menu_xazina_payment" name="გადარიცხვები" parent="menu_xazina_root" action="action_xazina_payment" sequence="20"/>
</odoo>
