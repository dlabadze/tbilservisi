<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_create_gatareba_wizard_form" model="ir.ui.view">
        <field name="name">create.gatareba.wizard.form</field>
        <field name="model">create.gatareba.wizard</field>
        <field name="arch" type="xml">
            <form string="გატარებების შექმნა">
                <sheet>
                    <group>
                        <group string="ანგარიშები">
                            <field name="journal_id"/>
                            <field name="debit_account_id"/>
                            <field name="credit_account_id"/>
                        </group>
                        <group string="ჩანაწერები">
                            <field name="xazina_type" readonly="1"/>
                            <field name="record_count" string="გასაგზავნი ჩანაწერები" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="xazina_ids" widget="many2many_tags" readonly="1"
                               string="შერჩეული ჩანაწერები"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_gatarebebi"
                            type="object"
                            string="გატარებების შექმნა"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
