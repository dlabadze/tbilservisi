<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_xazina_wizard_form" model="ir.ui.view">
        <field name="name">import.xazina.wizard.form</field>
        <field name="model">import.xazina.wizard</field>
        <field name="arch" type="xml">
            <form string="ხაზინის იმპორტი">
                <div class="alert alert-info" role="alert">
                    <strong>ექსელის ფაილის სვეტების სათაურები უნდა იყოს შემდეგი:</strong>
                    <ul class="mb-0">
                        <li>თარიღი <span class="text-muted">(ან: გადარიცხვის თარიღი)</span></li>
                        <li>წელი</li>
                        <li>მიმღების სახელი <span class="text-muted">(ან: მიმღების დასახელება)</span></li>
                        <li>თანხა ლარში <span class="text-muted">(ან: თანხა ლარებში, თანხა)</span></li>
                    </ul>
                </div>
                <group>
                    <field name="xazina_type" readonly="1"/>
                    <field name="excel_file" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                    <field name="start_row"/>
                </group>
                <footer>
                    <button name="action_generate_records" string="იმპორტი" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="გაუქმება" special="cancel" class="btn-secondary" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_xazina_wizard" model="ir.actions.act_window">
        <field name="name">ხაზინის ექსელის იმპორტი</field>
        <field name="res_model">import.xazina.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_import_xazina_wizard_form"/>
    </record>
</odoo>
