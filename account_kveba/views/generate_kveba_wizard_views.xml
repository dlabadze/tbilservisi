<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_generate_kveba_wizard_form" model="ir.ui.view">
        <field name="name">generate.kveba.wizard.form</field>
        <field name="model">generate.kveba.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Kveba">
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="excel_file" filename="excel_filename"/>
                            <field name="excel_filename" invisible="1"/>
                            <!-- <field name="journals"/> -->
                        </group>
                        <group>
                            <field name="cost" string="ღირებულება დღგ-ს გარეშე"/>
                            <field name="journals"/>
                            <field name="analytic_account" string="დეპარტამენტი"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate_kveba" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_generate_kveba_wizard" model="ir.actions.act_window">
        <field name="name">კვება/საჩუქარი</field>
        <field name="res_model">generate.kveba.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


    <record id="view_generate_sawvavi_wizard_form" model="ir.ui.view">
        <field name="name">generate.sawvavi.wizard.form</field>
        <field name="model">generate.sawvavi.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Kveba">
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="excel_file" filename="excel_filename"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="fuel_type" string="საწვავი"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="generate_sawvavi" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_generate_sawvavi_wizard" model="ir.actions.act_window">
        <field name="name">საწვავი</field>
        <field name="res_model">generate.sawvavi.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Inherit Invoice Tree View to Add Button -->
    <record id="view_invoice_tree_inherit_kveba" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.kveba</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                <button name="%(action_generate_kveba_wizard)d" 
                        string="კვება/საჩუქარი" 
                        type="action" 
                        class="btn-primary"
                        display="always"/>
                <button name="%(action_generate_sawvavi_wizard)d" 
                        string="საწვავი" 
                        type="action" 
                        class="btn-success"
                        display="always"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>

