<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="view_account_asset_form_inherit_extra" model="ir.ui.view">
			<field name="name">account.asset.form.inherit.extra</field>
			<field name="model">account.asset</field>
			<field name="inherit_id" ref="account_asset.view_account_asset_form"/>
			<field name="arch" type="xml">
				<xpath expr="//sheet/notebook" position="inside">
					<page string="Extra Values">
						<group>
							<field name="original_value_new"/>
							<field name="old_depre"/>
							<field name="already_depreciated_amount_import_new"/>
						</group>
					</page>
				</xpath>
			</field>
		</record>
	</data>
</odoo>


