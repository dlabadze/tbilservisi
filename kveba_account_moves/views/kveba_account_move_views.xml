<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kveba_account_move_wizard_form" model="ir.ui.view">
        <field name="name">kveba.account.move.wizard.form</field>
        <field name="model">kveba.account.move.wizard</field>
        <field name="arch" type="xml">
            <form string="კვება - გატარება">
                <sheet>
                    <group>
                        <field name="date"/>
                        <field name="excel_file" filename="excel_filename"/>
                        <field name="excel_filename" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate_journal_entries" string="გატარება" type="object" class="btn-primary"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_kveba_account_move_wizard" model="ir.actions.act_window">
        <field name="name">კვება - გატარება</field>
        <field name="res_model">kveba.account.move.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_invoice_tree_kveba_gatareba" model="ir.ui.view">
        <field name="name">account.move.tree.kveba.gatareba</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account_kveba.view_invoice_tree_inherit_kveba"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_kveba_account_move_wizard)d"
                        string="კვება - გატარება"
                        type="action"
                        class="btn-secondary"
                        display="always"/>
            </xpath>
        </field>
    </record>
</odoo>
