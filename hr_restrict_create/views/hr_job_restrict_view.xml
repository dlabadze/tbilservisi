<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!--
            Restrict "Create" and "Create and Edit" on the Department (department_id)
            field in the Job Position form view — for non-administrator users only.
            The 'groups' attribute on the xpath element limits where this change applies.
        -->
        <record id="view_hr_job_form_restrict_dept" model="ir.ui.view">
            <field name="name">hr.job.form.restrict.dept</field>
            <field name="model">hr.job</field>
            <field name="inherit_id" ref="hr.view_hr_job_form"/>
            <field name="arch" type="xml">
                <field name="department_id" position="attributes" groups="!base.group_system">
                    <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
                </field>
            </field>
        </record>
    </data>
</odoo>
