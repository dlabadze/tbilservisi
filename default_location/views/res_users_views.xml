<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_inherit_default_location" model="ir.ui.view">
        <field name="name">res.users.form.inherit.default.location</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[@name='preferences']" position="inside">
                <group string="Inventory">
                    <field name="def_location_id" options="{'no_create': False}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>


