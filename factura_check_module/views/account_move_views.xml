<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Add button to form view -->
        <record id="view_move_form_factura_check" model="ir.ui.view">
            <field name="name">account.move.form.factura.check</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_check_factura_numbers" 
                            string="ფაქტურის ნომრების შემოწმება" 
                            type="object"
                            class="oe_highlight"
                            invisible="not combined_invoice_id or not combined_invoice_id.factura_num"/>
                </xpath>
            </field>
        </record>

        <!-- Server action for list view -->
        <record id="action_check_factura_numbers" model="ir.actions.server">
            <field name="name">ფაქტურის ნომრების შემოწმება</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
if records:
    action = records.action_check_factura_numbers()
            </field>
        </record>
    </data>
</odoo>

