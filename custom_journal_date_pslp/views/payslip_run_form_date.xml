<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_payslip_run_form_inherit_journal_date" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.inherit.journal.date</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_end']" position="after">
                <label for="journal_entry_date" string="დარიცხვის თარიღი"/>
                <field name="journal_entry_date" string="Journal Date" />
            </xpath>
            <xpath expr="//field[@name='country_code']" position="after">
                <field name="structure_id"/>
            </xpath>
        </field>
    </record>
</odoo>