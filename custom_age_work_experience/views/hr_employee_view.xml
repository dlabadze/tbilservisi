<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_extended_details_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.extended_details.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
		  <xpath expr="//field[@name='birthday']" position="after">
				<field name="age"/>
				<field name="work_experience_months" string="Work Experience (Months)"/>
			</xpath>
        </field>
    </record>
</odoo>