<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_inherit_reference_code_btn" model="ir.ui.view">
        <field name="name">product.template.form.inherit.reference.code.btn</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="action_generate_reference_code"
                        type="object"
                        string="კოდის გენერაცია"
                        class="btn-secondary"
                        groups="base.group_user"/>
            </xpath>
        </field>
    </record>
</odoo>


