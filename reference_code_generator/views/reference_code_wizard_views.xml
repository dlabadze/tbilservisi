<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_reference_code_generator_wizard_form" model="ir.ui.view">
        <field name="name">reference.code.generator.wizard.form</field>
        <field name="model">reference.code.generator.wizard</field>
        <field name="arch" type="xml">
            <form string="კოდის გენერაცია" create="false" edit="false">
                <group>
                    <field name="generated_code" readonly="1"/>
                </group>
                <footer>
                    <button string="დააგენერირე" name="action_generate" type="object" class="btn-primary"/>
                    <button string="დახურვა" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_reference_code_generator_wizard" model="ir.actions.act_window">
        <field name="name">კოდის გენერაცია</field>
        <field name="res_model">reference.code.generator.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_reference_code_generator_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_product_tmpl_id': active_id}</field>
    </record>
</odoo>


