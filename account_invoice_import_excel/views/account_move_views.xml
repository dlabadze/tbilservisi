<odoo>
    <!-- Server Action to Update Invoice Number Helper -->
    <record id="server_action_update_invoice_id_helper" model="ir.actions.server">
        <field name="name">ფაქტურის ნომრის განახლება</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_update_invoice_id_helper()</field>
    </record>

    <record id="view_move_list_inherit_excel_import" model="ir.ui.view">
        <field name="name">account.move.list.import.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="extension_views.view_move_list_batch_actions"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='button_factura']" position="after">

                <button name="%(action_invoice_import_wizard)d"
                        string="Excel Upload"
                        type="action"
                        display="always"
                        class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_form_helper_field" model="ir.ui.view">
        <field name="name">account.move.form.helper.field</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_number']" position="after">
                <field name="get_invoice_id_helper"/>
                <field name="get_zednd_number_helper"/>

            </xpath>

            <xpath expr="//field[@name='get_invoice_id']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <xpath expr="//field[@name='invoice_number']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
        </field>
    </record>
<!--    x_studio_char_field_5le_1jeop8mrp-->
</odoo>
