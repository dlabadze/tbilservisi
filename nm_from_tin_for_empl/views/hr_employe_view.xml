<odoo>
    <record id="res_partner_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='public']//group[@name='departure']//field[@name='departure_date']" position="after">
                <field name="rs_acc"/>
                <field name="rs_pass"/>
                <field name="buyer_tin"/>
                <field name="company_review"/>
            </xpath>
            <xpath expr="//field[@name='job_title']" position="after">
                <button name="button_get_name_from_tin" string="Get Name from TIN" type="object"/>
            </xpath>
        </field>
    </record>
</odoo>