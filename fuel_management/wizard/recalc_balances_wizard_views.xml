<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>
		<record id="view_fuel_recalc_wizard_form" model="ir.ui.view">
			<field name="name">fuel.management.recalc.wizard.form</field>
			<field name="model">fuel.management.recalc.wizard</field>
			<field name="arch" type="xml">
				<form string="ნაშთების გადათვლა">
					<sheet>
						<group>
							<field name="date_from" required="1"/>
							<field name="date_to" required="1"/>
						</group>
					</sheet>
					<footer>
						<button string="გადათვლა" type="object" name="action_recalculate" class="btn-primary"/>
						<button string="გაუქმება" special="cancel" class="btn-secondary"/>
					</footer>
				</form>
			</field>
		</record>

		<record id="action_fuel_recalc_wizard" model="ir.actions.act_window">
			<field name="name">ნაშთების გადათვლა</field>
			<field name="res_model">fuel.management.recalc.wizard</field>
			<field name="view_mode">form</field>
			<field name="target">new</field>
		</record>
	</data>
</odoo>



