<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>
		<record id="view_fuel_date_wizard_form" model="ir.ui.view">
			<field name="name">fuel.management.date.wizard.form</field>
			<field name="model">fuel.management.date.wizard</field>
			<field name="arch" type="xml">
				<form string="Filter by Date">
					<sheet>
						<group>
							<field name="date_from"/>
							<field name="date_to"/>
						</group>
					</sheet>
					<footer>
						<button string="გახსნა" type="object" name="action_open_records" class="btn-primary"/>
						<button string="გაუქმება" special="cancel" class="btn-secondary"/>
					</footer>
				</form>
			</field>
		</record>

		<record id="action_fuel_date_wizard" model="ir.actions.act_window">
			<field name="name">Filter by Date</field>
			<field name="res_model">fuel.management.date.wizard</field>
			<field name="view_mode">form</field>
			<field name="target">new</field>
		</record>

		<!-- Menu entry under Fuel Management -->
		<menuitem id="menu_fuel_management_filter" name="ფილტრი თარიღით" parent="menu_fuel_management_root" action="action_fuel_date_wizard" sequence="20"/>

		<!-- Action menu binding on fuel.management list -->
		<record id="action_open_fuel_date_wizard_from_list" model="ir.actions.server">
			<field name="name">Filter by Date</field>
			<field name="model_id" ref="model_fuel_management"/>
			<field name="binding_model_id" ref="model_fuel_management"/>
			<field name="binding_type">action</field>
			<field name="state">code</field>
			<field name="code">action = env.ref('fuel_management.action_fuel_date_wizard').read()[0]</field>
		</record>
	</data>
</odoo>


