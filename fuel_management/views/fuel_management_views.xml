<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>
		<record id="view_fuel_management_tree" model="ir.ui.view">
			<field name="name">fuel.management.tree</field>
			<field name="model">fuel.management</field>
			<field name="arch" type="xml">
				<list string="Fuel Management" js_class="fuel_management_list_with_date_filter" default_order="date desc,id desc">
					<field name="date"/>
					<field name="parent_department_id"/>
					<field name="department_id"/>
					<field name="writeoff_location_id"/>
					<field name="vehicle_id"/>
					<field name="fuel_product_id"/>
					<field name="employee_id"/>
					<field name="fuel"/>
					<field name="ownership_type"/>
					<field name="start_balance" sum="1"/>
					<field name="filled_qty" sum="1"/>
					<field name="other_received" sum="1"/>
					<field name="other_transferred" sum="1"/>
					<field name="final_balance" sum="1"/>
					<field name="consumed_qty" sum="1"/>
					<field name="start_odometer" sum="1"/>
					<field name="odometer" sum="1"/>
					<field name="monthly_mileage" sum="1"/>
					<field name="worked_hours" sum="1"/>
					<field name="total_worked_hours" sum="1"/>
					<field name="start_worked_hours" sum="1"/>
				</list>
			</field>
		</record>

		<record id="view_fuel_management_form" model="ir.ui.view">
			<field name="name">fuel.management.form</field>
			<field name="model">fuel.management</field>
			<field name="arch" type="xml">
				<form string="Fuel Management">
					<sheet>
						<group>
							<group>
								<field name="date"/>
								<field name="parent_department_id"/>
								<field name="department_id"/>
								<field name="writeoff_location_id" readonly="1"/>
								<field name="vehicle_id"/>
								<field name="fuel_product_id"/>
								<field name="employee_id"/>
								<field name="fuel" readonly="1"/>
								<field name="ownership_type" readonly="1"/>
							</group>
							<group>
								<field name="start_balance"/>
								<field name="filled_qty"/>
								<field name="other_received"/>
								<field name="other_transferred"/>
								<field name="final_balance"/>
								<field name="consumed_qty"/>
							</group>
						</group>
						<group>
							<group>
								<field name="odometer"/>
								<field name="monthly_mileage"/>
							</group>
							<group>
								<field name="start_odometer"/>
								<field name="worked_hours"/>
								<field name="total_worked_hours"/>
								<field name="start_worked_hours"/>
							</group>
						</group>
					</sheet>
					<chatter/>
				</form>
			</field>
		</record>

		<record id="action_fuel_management" model="ir.actions.act_window">
			<field name="name">Fuel Management</field>
			<field name="res_model">fuel.management</field>
			<field name="view_mode">list,form</field>
			<field name="help" type="html">
				<p class="o_view_nocontent_smiling_face">
					Create your first Fuel Management record
				</p>
			</field>
		</record>

		<menuitem id="menu_fuel_management_root" name="Fuel Management" sequence="25" parent="fleet.menu_root"/>
		<menuitem id="menu_fuel_management_records" name="ჩანაწერები" parent="menu_fuel_management_root" action="action_fuel_management"/>
	</data>
</odoo>


