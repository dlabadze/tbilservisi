<odoo>
    <record id="product_template_only_form_view_uom_force_change" model="ir.ui.view">
        <field name="name">product.template.only.form.uom.force.change</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_uom_force_change_wizard"
                    type="object"
                    string="განზ. ერთეულის შეცვლა"
                    class="btn-secondary"
                    groups="stock.group_stock_manager"
                />
            </xpath>
        </field>
    </record>
</odoo>
