<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bazris_kvleva_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">bazris.kvleva.excel.import.wizard.form</field>
        <field name="model">bazris.kvleva.excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Excel">
                <group>
                    <field name="filename" invisible="1"/>
                    <field name="excel_file" filename="filename" required="1"/>
                </group>
                <footer>
                    <button string="Import" name="action_import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bazris_kvleva_excel_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Excel</field>
        <field name="res_model">bazris.kvleva.excel.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

