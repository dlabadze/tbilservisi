<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_valuation_layer_date_change_wizard_form" model="ir.ui.view">
        <field name="name">stock.valuation.layer.date.change.wizard.form</field>
        <field name="model">stock.valuation.layer.date.change.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Valuation Layer Date">
                <group>
                    <field name="date"/>
                </group>
                <footer>
                    <button name="action_apply_date_change" string="დადასტურება" type="object" class="btn-primary"/>
                    <button string="გაუქმება" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_valuation_layer_date_change_wizard" model="ir.actions.act_window">
        <field name="name">თარიღის შეცვლა</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.valuation.layer.date.change.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_stock_valuation_layer_date_change_wizard_form"/>
        <field name="target">new</field>
        <field name="binding_model_id" ref="stock_account.model_stock_valuation_layer"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
