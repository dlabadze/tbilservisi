<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="users_passwords_editor_view_list" model="ir.ui.view">
            <field name="name">users.passwords.for.editor.list</field>
            <field name="model">users.passwords.for.editor</field>
            <field name="arch" type="xml">
                <list string="User Passwords for File Editor" editable="bottom">
                    <field name="user_id"/>
                    <field name="password" password="True"/>
                </list>
            </field>
        </record>

        <record id="users_passwords_editor_action" model="ir.actions.act_window">
            <field name="name">File Editor Passwords</field>
            <field name="res_model">users.passwords.for.editor</field>
            <field name="view_mode">list</field>
        </record>

        <menuitem
            id="menu_users_passwords_editor"
            name="File Editor Passwords"
            action="users_passwords_editor_action"
            sequence="100"/>
    </data>
</odoo>
