<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_partner_view_form_inherit_file_editor" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.file.editor</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="File Editor" name="file_editor">
                        <group>
                            <field name="password_fileeditor" widget="password"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
