<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="external_file_editor.ExternalFileEditor">
        <div class="o_external_file_editor">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card">
                            <div class="card-body text-center p-5">
                                <t t-if="state.loading">
                                    <div class="spinner-border text-primary mb-3" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <h4>ფაილი იგზავნება რედაქტორში...</h4>
                                    <p class="text-muted">გთხოვთ დაელოდოთ...</p>
                                </t>
                                
                                <t t-elif="state.error">
                                    <div class="alert alert-danger mb-3" role="alert">
                                        <i class="fa fa-exclamation-triangle fa-2x mb-3"/>
                                        <h4>შეცდომა</h4>
                                        <p><t t-esc="state.error"/></p>
                                    </div>
                                    <button class="btn btn-secondary" t-on-click="() => this.action.doAction({type: 'ir.actions.act_window_close'})">
                                        დახურვა
                                    </button>
                                </t>
                                
                                <t t-else="">
                                    <div class="text-success mb-3">
                                        <i class="fa fa-check-circle fa-3x"/>
                                    </div>
                                    <!-- <h4>წარმატება!</h4> -->
                                    <p class="text-muted">ფაილი გაიგზავნა გარე რედაქტორში.</p>
                                    <!-- <small class="text-muted">ეს ფანჯარა ავტომატურად დაიხურება...</small> -->
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
