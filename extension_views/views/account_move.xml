<odoo>
    <data>
        <record id="view_move_form_inherit" model="ir.ui.view">
            <field name="name">account.move.form.inherit.additional.fields</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@id='header_left_group']" position="inside">
                    <field name="show_all_fields"/>
                    <field name="combined_invoice_id" invisible="1"/>
                    <field name="invoice_number"/>
                    <field name="get_invoice_id" invisible="0"/>
                    <field name="factura_num" invisible="1"/>
                    <field name="invoice_id" invisible="1"/>
                    <field name="status" invisible="1"/>
                    <field name="begin_date" invisible="not show_all_fields"/>
                    <field name="delivery" invisible="not show_all_fields"/>
                    <field name="trans_id" invisible="not show_all_fields"/>
                    <field name="trans_txt" invisible="not is_trans_id_4 or not show_all_fields" placeholder="აუცილებელი ველი"/>
                    <field name="is_trans_id_4" invisible="1"/>
                    <field name="start_location" invisible="not show_all_fields"/>
                    <field name="editable_end_location" invisible="not show_all_fields"/>
                    <field name="buyer_type" invisible="not show_all_fields"/>
                </xpath>
                <xpath expr="//group[@id='header_right_group']" position="inside">
                    <field name="car_number" invisible="not show_all_fields"/>
                    <field name="driver_type" invisible="not show_all_fields"/>
                    <field name="driver_id" invisible="not show_all_fields"/>
                    <field name="driver_name" invisible="not show_all_fields"/>
                    <field name="transport_cost_payer" invisible="not show_all_fields"/>
                    <field name="transport_cost" invisible="not show_all_fields"/>
                    <field name="comment"/>
                    <field name="product_comment"/>
                    <field name="error_field" invisible="1"/>
                    <field name="partner_vat" invisible="1"/>
                    <field name="completed_soap" invisible="1"/>
                    <field name="is_soap_completed" invisible="1"/>
                    <field name="error_field" invisible="1"/>
                    <field name="extracted_data" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='invoice_origin']" position="after">
                    <group string="Other Info">
                        <field name="warehouse_id"/>
                        <field name="warehouse_address"/>
                    </group>
                </xpath>
                <xpath expr="//header" position="inside">
                    <button name="button_send_soap_request" string="RS- ზედნადები" type="object"
                            class="oe_highlight"
                            confirm="გსურთ ზედნადების ატვირთვა?"
                            invisible="state != 'posted' or move_type == 'in_invoice' or not show_all_fields"/>

                    <button name="button_factura" string="RS - ფაქტურა" type="object"
                            class="oe_highlight"
                            confirm="გსურთ ფაქტურის ატვირთვა?"
                            invisible="state != 'posted' or move_type == 'in_invoice'"/>

                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="after">
                    <field name="barcode"/>
                    <field name="unit_id"/>
                    <field name="unit_txt"/>
                </xpath>
            </field>
        </record>

        <!-- List view with batch action buttons -->
        <record id="view_move_list_batch_actions" model="ir.ui.view">
            <field name="name">account.move.list.batch.actions</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <header>
                        <button name="button_send_soap_request" 
                                string="📤 RS ზედნადები ჯამური"
                                type="object" 
                                class="btn-primary"
                                confirm="გსურთ შერჩეული ზედნადებების ატვირთვა?"/>
                        <button name="button_factura" 
                                string="📋 RS ფაქტურა ჯამური"
                                type="object" 
                                class="btn-primary"
                                confirm="გსურთ შერჩეული ფაქტურების ატვირთვა?"/>
                    </header>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
