<odoo>
    <record id="product_product_normal_form_view_inherit" model="ir.ui.view">
        <field name="name">product.product.normal.form.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <field name="unit_id"/>
                <field name="unit_txt"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <notebook>
                    <page string="Buyer Info">
                        <field name="buyer_info_ids">
                            <list>
                                <field name="buyer_tin" string="მომწოდებელი/კლიენტი"/>
                                <field name="barcode" string="ბარკოდი"/>
                                <field name="koef"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>

