<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inventory_line_tree_scroll" model="ir.ui.view">
        <field name="name">inventory.request.form.scroll</field>
        <field name="model">inventory.request</field>
        <field name="inherit_id" ref="inventory_requests.view_inventory_request_form"/>
        <field name="arch" type="xml">
           <xpath expr="//notebook/page[@string='Inventory Lines']/field[@name='line_ids']/list" position="attributes">
            <attribute name="js_class">inventory_request_scroll_list</attribute>
        </xpath>
        </field>
    </record>
</odoo>
