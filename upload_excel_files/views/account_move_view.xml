<odoo>
    <record id="view_move_form_inherit_basis" model="ir.ui.view">
        <field name="name">account.move.form.inherit.basis</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_left_group']/div[@class='o_col'][field[@name='partner_id']]" position="after">
                <label for="identification_code" string="საიდენტიფიკაციო კოდი" style="font-weight:bold;"/>
                <field name="identification_code" nolabel="1"/>

                <label for="basis" string="საფუძველი" style="font-weight:bold;"/>
                <field name="basis" nolabel="1"/>

                <label for="contract_num" string="კონტრაქტის ნომერი" style="font-weight:bold;"/>
                <field name="contract_num" nolabel="1"/>

                <label for="danishnuleba" string="დანიშნულება" style="font-weight:bold;"/>
                <field name="danishnuleba" nolabel="1"/>
            </xpath>
        </field>
    </record>
</odoo>
