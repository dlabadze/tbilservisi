<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_move_operations_internal_account" model="ir.ui.view">
        <field name="name">stock.move.operations.internal.account</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_stock_move_operations"/>
        <field name="arch" type="xml">
            <!-- Add move_account_ang field in the move list view -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="move_account_ang" 
                       string="Reconciliation Account"
                       options="{'no_create': True}"
                       invisible="not is_internal_transfer"
                       optional="hide"/>
                <field name="analytic_distribution" 
                       widget="analytic_distribution"
                       groups="analytic.group_analytic_accounting"
                       invisible="not is_internal_transfer"
                       optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
