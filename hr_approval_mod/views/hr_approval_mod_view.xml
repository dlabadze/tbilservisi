<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Update Approval Category View -->
    <record id="approval_category_view_form_inherit_brdzaneba" model="ir.ui.view">
        <field name="name">approval.category.view.form.inherit.brdzaneba</field>
        <field name="model">approval.category</field>
        <field name="inherit_id" ref="approvals.approval_category_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="ბრძანება">
                    <field name="has_brdzaneba" widget="radio" options="{'horizontal': True}"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Update Approval Request View -->
    <record id="approval_request_view_form_inherit_brdzaneba" model="ir.ui.view">
        <field name="name">approval.request.view.form.inherit.brdzaneba</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group[1]" position="after">
                <field name="has_brdzaneba" invisible="1"/>
                <field name="brdzaneba_kind" invisible="1"/>

                <group string="დანიშვნა" invisible="has_brdzaneba == 'no' or brdzaneba_kind != 'appointment'">
                    <group>
                        <field name="brdzaneba_date" required="has_brdzaneba == 'required'" invisible="category_id not in [10, 11, 12, 14, 15, 44, 45, 46, 47, 48 ]"/>
                        <field name="brdzaneba_employee_id" required="has_brdzaneba == 'required'" options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"/>
                        <field name="brdzaneba_identification_id"/>
                        <field name="brdzaneba_current_department_id" context="{'show_short_name': True}"/>
                        <field name="brdzaneba_current_job_id"/>
                    </group>
                    <group>
                        <field name="brdzaneba_start_date" invisible="category_id not in [10, 11, 12, 13, 14, 15, 44, 45, 46, 47, 48, 39, 41, 23, 32]"/>
                        <field name="brdzaneba_end_date" invisible="category_id not in [10, 11, 12, 13, 14, 15, 39, 44, 45, 46, 47, 48, 23, 41, 61]"/>
                        <field name="brdzaneba_department_id" context="{'show_short_name': True}" invisible="category_id not in [10, 11, 12, 13, 14, 15, 44]" options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"/>
                        <field name="brdzaneba_job_id" invisible="category_id not in [10, 11, 12, 13, 14, 15, 44]" options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"/>
                        <field name="brdzaneba_shtati" invisible="category_id not in [10, 11, 12, 13, 44, 14]"/>
                        <field name="brdzaneba_salary" invisible="category_id not in [10, 11, 12, 13, 44, 14]"/>
                    </group>
                </group>

                <group string="დანიშვნა დროებით" invisible="has_brdzaneba == 'no' or brdzaneba_kind != 'temporary_appointment'">
                    <group>
                        <field name="brdzaneba_date" required="has_brdzaneba == 'required'" invisible="category_id not in [10, 11, 12, 14, 15, 44, 45, 46, 47, 48 ]"/>
                        <field name="brdzaneba_employee_id" required="has_brdzaneba == 'required'" options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"/>
                        <field name="brdzaneba_identification_id"/>
                        <field name="brdzaneba_current_department_id" context="{'show_short_name': True}"/>
                        <field name="brdzaneba_current_job_id"/>
                    </group>
                    <group>
                        <field name="brdzaneba_start_date" invisible="category_id not in [10, 11, 12, 13, 14, 15, 44, 45, 46, 47, 48, 39, 41, 23, 32]"/>
                        <field name="brdzaneba_end_date" invisible="category_id not in [10, 11, 12, 13, 14, 15, 39, 44, 45, 46, 47, 48, 23, 41, 61]"/>
                        <field name="brdzaneba_department_id" context="{'show_short_name': True}" invisible="category_id not in [10, 11, 12, 13, 14, 15, 44]" options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"/>
                        <field name="brdzaneba_job_id" invisible="category_id not in [10, 11, 12, 13, 14, 15, 44]" options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"/>
                        <field name="brdzaneba_shtati" invisible="category_id not in [10, 11, 12, 13, 44, 14]"/>
                        <field name="brdzaneba_salary" invisible="category_id not in [10, 11, 12, 13, 44, 14]"/>
                    </group>
                </group>

                <group invisible="has_brdzaneba == 'no'">
                    <field name="brdzaneba_safudzveli" invisible="category_id in [42, 43, 26, 27, 60]"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
