<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_fields_update_wizard_form" model="ir.ui.view">
        <field name="name">employee.fields.update.wizard.form</field>
        <field name="model">employee.fields.update.wizard</field>
        <field name="arch" type="xml">
            <form string="სახელფასო კომპონენტების ატვირთვა">
                <sheet>
                    <group>
                        <group>
                            <field name="excel_file" filename="filename" widget="binary"/>
                            <field name="filename" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Confirm"
                            name="action_confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_employee_fields_update_wizard" model="ir.actions.act_window">
        <field name="name">სახელფასო კომპონენტების ატვირთვა</field>
        <field name="res_model">employee.fields.update.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
