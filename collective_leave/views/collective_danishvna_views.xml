<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="collective_danishvna_view_form" model="ir.ui.view">
        <field name="name">collective.danishvna.view.form</field>
        <field name="model">collective.danishvna</field>
        <field name="arch" type="xml">
            <form string="კოლექტიური დანიშვნა">
                <header>
                    <button
                        name="action_compute_employees"
                        string="თანამშრომლების გენერირება"
                        type="object"
                        class="btn-primary"/>
                    <button
                        name="create_approval_request"
                        string="დადასტურება"
                        type="object"
                        class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_open_approval_requests"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o">
                            <field name="approval_request_count" widget="statinfo" string="ბრძანებები"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="registration_date"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="მიმდინარე მდგომარეობა">
                            <field name="department_id"/>
                            <field name="parent_department_id"/>
                            <field name="job_id"/>
                        </group>
                        <group string="ახალი მდგომარეობა">
                            <field name="new_department_id"/>
                            <field name="new_parent_department_id"/>
                            <field name="new_job_id"/>
                            <field name="salary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="თანამშრომლები">
                            <field name="collective_danishvna_emp_ids">
                                <list editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="job_id"/>
                                    <field name="is_checked"/>
                                </list>
                            </field>
                        </page>
                        <page string="მონიშნული">
                            <field name="employee_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="department_id"/>
                                    <field name="job_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="collective_danishvna_view_list" model="ir.ui.view">
        <field name="name">collective.danishvna.view.list</field>
        <field name="model">collective.danishvna</field>
        <field name="arch" type="xml">
            <list string="კოლექტიური დანიშვნა">
                <field name="registration_date"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="new_department_id"/>
                <field name="new_job_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <record id="collective_danishvna_action_window" model="ir.actions.act_window">
        <field name="name">კოლექტიური დანიშვნა</field>
        <field name="res_model">collective.danishvna</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
