<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_custom_attendance" model="ir.ui.view">
        <field name="name">hr.payslip.form.custom.attendance</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='input_line_ids']" position="after">
                <group name="work_days">
                    <group name="wok_days">
                        <field name="x_worked_days_attendance"/>
                    </group>
                    <group name="work_rate">
                        <field name="x_worked_days_rate"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
