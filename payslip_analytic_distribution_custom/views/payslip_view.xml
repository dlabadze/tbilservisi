<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_custom_attendance" model="ir.ui.view">
        <field name="name">hr.payslip.form.custom.attendance</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
              <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='worked_days_input']/field[@name='worked_days_line_ids']/list[1]/field[@name='number_of_days']" position="after">
                <field name="x_worked_days_attendance" optional="show"/>
                <field name="x_worked_days_rate" optional="show"/>
              </xpath>
        </field>
    </record>
</odoo>
