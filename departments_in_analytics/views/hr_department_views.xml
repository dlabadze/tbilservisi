<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_department_form_analytic" model="ir.ui.view">
        <field name="name">hr.department.form.analytic</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group/group/field[@name='color']" position="after">
                <field name="analytic_account_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="action_sync_department_analytic" model="ir.actions.server">
        <field name="name">Sync Analytic Account</field>
        <field name="model_id" ref="hr.model_hr_department"/>
        <field name="binding_model_id" ref="hr.model_hr_department"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">records.action_sync_analytic_account()</field>
    </record>
</odoo>
