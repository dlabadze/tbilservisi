<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_account_filter_form" model="ir.ui.view">
        <field name="name">hr.payslip.account.filter.form</field>
        <field name="model">hr.payslip.account.filter</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="account_ids" widget="many2many_tags"/>
                        <field name="category_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_payslip_account_filter_tree" model="ir.ui.view">
        <field name="name">hr.payslip.account.filter.tree</field>
        <field name="model">hr.payslip.account.filter</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="account_ids" widget="many2many_tags"/>
                <field name="category_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="action_hr_payslip_account_filter" model="ir.actions.act_window">
        <field name="name">Partner Assignment Rules</field>
        <field name="res_model">hr.payslip.account.filter</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_payslip_account_filter_config"
              name="Partner Account Filters"
              parent="hr_work_entry_contract_enterprise.menu_hr_payroll_configuration"
              action="action_hr_payslip_account_filter"
              sequence="150"/>
</odoo>