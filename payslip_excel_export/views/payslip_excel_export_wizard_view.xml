<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payslip_excel_export_wizard_form" model="ir.ui.view">
        <field name="name">payslip.excel.export.wizard.form</field>
        <field name="model">payslip.excel.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Payslips to Excel">
                <sheet>
                    <div class="oe_title">
                        <h1>Export Payslips to Excel</h1>
                    </div>

                    <group>
                        <group string="Period">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Filter">
                            <field name="department_id"/>
                        </group>
                    </group>

                    <separator string="Columns"/>
                    <p class="text-muted">
                        Add, remove or reorder columns below. Drag the ☰ handle to reorder.
                        Pick a <b>Field</b> for any real payslip field, or pick a
                        <b>Virtual Column</b> for attendance day-type counts (X / D / G).
                    </p>

                    <field name="column_ids">
                        <list editable="bottom"
                              string="Columns"
                              handle="sequence">
                            <field name="sequence" widget="handle"/>
                            <field name="field_id"
                                   string="Payslip Field"
                                   optional="show"
                                   domain="[('model', '=', 'hr.payslip'),
                                            ('ttype', 'not in', ['one2many','many2many','binary','html'])]"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="virtual_key" optional="show"/>
                            <field name="label" required="1"/>
                            <field name="col_width" optional="show"/>
                        </list>
                    </field>

                    <div class="alert alert-info" role="alert">
                        <strong>Department filter rules:</strong><br/>
                        • No department → all departments.<br/>
                        • Department with <b>no parent</b> → includes all child departments.<br/>
                        • Department <b>with a parent</b> → only that department.
                    </div>
                </sheet>
                <footer>
                    <button name="action_export"
                            string="Export to Excel"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_payslip_excel_export_wizard" model="ir.actions.act_window">
        <field name="name">Export Payslips to Excel</field>
        <field name="res_model">payslip.excel.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_payslip_excel_export_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
