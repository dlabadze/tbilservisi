<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- 
            Remove domain restriction on location_dest_id in barcode interface
            to allow selection from ALL available locations instead of only
            children of picking's default destination location
        -->
        <record id="view_stock_move_line_detailed_operation_tree_unrestricted" model="ir.ui.view">
            <field name="name">stock.move.line.operations.list.unrestricted</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
            <field name="arch" type="xml">
            
                <!-- Completely replace the domain to show ALL internal/transit locations -->
                <xpath expr="//field[@name='location_dest_id']" position="attributes">
                    <attribute name="domain">[('usage', 'in', ['internal', 'transit'])]</attribute>
                    <attribute name="context">{'default_usage': 'internal'}</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

