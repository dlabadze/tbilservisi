<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_leave_allocation_import_wizard_form" model="ir.ui.view">
        <field name="name">leave.allocation.import.wizard.form</field>
        <field name="model">leave.allocation.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Leave Allocation Excel Import">
                <sheet>
                    <group>
                        <field name="excel_field" filename="filename" widget="binary"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_leave_allocation_import_wizard" model="ir.actions.act_window">
        <field name="name">ექსელის ატვირთვა</field>
        <field name="res_model">leave.allocation.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_leave_allocation_import_wizard"
              name="ექსელის ატვირთვა"
              parent="hr_holidays.menu_hr_holidays_root"
              action="action_leave_allocation_import_wizard"
              sequence="100"/>
</odoo>
