<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_repair_inherit" model="ir.ui.view">
        <field name="name">res.users.form.repair.inherit</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Repair Settings">
                    <group>
                        <field name="default_repair_partner_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
