<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_move_form_inherit_editable_journal_items" model="ir.ui.view">
            <field name="name">account.move.form.inherit.editable.items</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='line_ids']/list/field[@name='debit']" position="attributes">
                    <attribute name="readonly">parent.move_type in ('out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt') and display_type in ('line_section', 'line_note', 'product')</attribute>
                </xpath>

                <xpath expr="//field[@name='line_ids']/list/field[@name='credit']" position="attributes">
                    <attribute name="readonly">parent.move_type in ('out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt') and display_type in ('line_section', 'line_note', 'product')</attribute>
                </xpath>

            </field>
        </record>
    </data>
</odoo>