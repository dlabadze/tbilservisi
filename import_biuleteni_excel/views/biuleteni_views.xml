<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_biuleteni_list_inherit_excel_import" model="ir.ui.view">
        <field name="name">biuleteni.list.inherit.excel.import</field>
        <field name="model">biuleteni</field>
        <field name="inherit_id" ref="biuleteni.view_biuleteni_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button
                        name="action_open_excel_import_wizard"
                        string="Excel Import"
                        type="object"
                        display="always"
                    />
                </header>
            </xpath>
        </field>
    </record>
</odoo>
