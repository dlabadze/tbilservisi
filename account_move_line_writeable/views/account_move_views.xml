<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_writable_debit_credit" model="ir.ui.view">
        <field name="name">account.move.form.inherit.writable.debit.credit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
        <xpath expr="//page[@id='aml_tab']//field[@name='line_ids']//list//field[@name='debit']" position="attributes">
                <attribute name="readonly">display_type in ('line_section', 'line_note')</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//page[@id='aml_tab']//field[@name='line_ids']//list//field[@name='credit']" position="attributes">
                <attribute name="readonly">display_type in ('line_section', 'line_note')</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
