<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_excel_field_update_wizard_form" model="ir.ui.view">
        <field name="name">hr.employee.excel.field.update.wizard.form</field>
        <field name="model">hr.employee.excel.field.update.wizard</field>
        <field name="arch" type="xml">
            <form string="თანამშრომლის ველების ატვირთვა">
                <sheet>
                    <group>
                        <field name="excel_file" filename="filename" widget="binary"/>
                        <field name="filename" invisible="1"/>
                    </group>
                    <group invisible="not result_message">
                        <field name="result_message" nolabel="1" readonly="1"/>
                        <field name="missed_file" filename="missed_filename" readonly="1" invisible="not missed_file"/>
                        <field name="missed_filename" invisible="1"/>
                    </group>
                    <div class="text-muted">
                        <p>ექსელის ფორმატი:</p>
                        <ul>
                            <li>1-ლი რიგი — ველების ტექნიკური სახელები (მაგ. identification_id, birthday)</li>
                            <li>2-ე რიგი — ქართული სათაურები (ინფორმაციული)</li>
                            <li>3-ე რიგიდან — მონაცემები</li>
                            <li>თანამშრომელი მოიძებნება პირადი ნომრით (identification_id)</li>
                            <li>სვეტები ტექნიკური სახელის გარეშე იგნორირდება</li>
                            <li>ცარიელი უჯრები იგნორირდება — არსებული მნიშვნელობა არ იცვლება</li>
                        </ul>
                    </div>
                </sheet>
                <footer>
                    <button name="action_import_excel"
                            string="ატვირთვა"
                            type="object"
                            class="btn-primary"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_employee_excel_field_update_wizard" model="ir.actions.act_window">
        <field name="name">თანამშრომლის ველების ატვირთვა</field>
        <field name="res_model">hr.employee.excel.field.update.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
