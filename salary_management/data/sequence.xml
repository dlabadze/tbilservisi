<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Salary Import Sequence -->
        <record id="seq_salary_import" model="ir.sequence">
            <field name="name">Salary Import Sequence</field>
            <field name="code">salary.import</field>
            <field name="prefix">SAL/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <!-- Insurance Import Sequence -->
        <record id="seq_insurance_import" model="ir.sequence">
            <field name="name">Insurance Import Sequence</field>
            <field name="code">insurance.import</field>
            <field name="prefix">INS/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <!-- Salary Payment Import Sequence -->
        <record id="seq_salary_payment_import" model="ir.sequence">
            <field name="name">Salary Payment Import Sequence</field>
            <field name="code">salary.payment.import</field>
            <field name="prefix">PAY/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>