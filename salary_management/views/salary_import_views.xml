<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Salary Import Form View -->
    <record id="view_salary_import_form" model="ir.ui.view">
        <field name="name">salary.import.form</field>
        <field name="model">salary.import</field>
        <field name="arch" type="xml">
            <form string="Salary Import">
                <header>
                    <button name="action_import_excel" 
                            string="Import Excel" 
                            type="object" 
                            class="oe_highlight" 
                            invisible="state != 'draft'"/>
                    <!-- <button name="action_generate_journal_entries" 
                            string="Generate Journal Entries" 
                            type="object" 
                            class="oe_highlight" 
                            invisible="state != 'imported'"/> -->
                    <button name="action_generate_journal_entries_by_field" 
                            string="Generate Journal Entries (3139)" 
                            type="object" 
                            class="btn-primary" 
                            invisible="state != 'imported'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,imported,posted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_journal_entries" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-pencil-square-o" 
                                invisible="journal_entry_count == 0">
                            <field name="journal_entry_count" widget="statinfo" string="Journal Entries"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="department_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="excel_file" 
                                   filename="excel_filename" 
                                   required="state == 'draft'" 
                                   readonly="state != 'draft'"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Salary Lines">
                            <field name="line_ids">
                                <list>
                                    <field name="partner_id"/>
                                    <field name="partner_vat"/>
                                    <field name="full_name"/>
                                    <field name="base_salary" sum="Total"/>
                                    <field name="total_salary" sum="Total"/>
                                    <field name="pension" sum="Total"/>
                                    <field name="company_tax" sum="Total"/>
                                    <field name="income_tax" sum="Total"/>
                                    <field name="net_amount" sum="Total"/>
                                    <field name="vacation_salary" sum="Total" optional="show"/>
                                    <field name="bulletin_salary" sum="Total" optional="show"/>
                                    <field name="bonus_salary" sum="Total" optional="show"/>
                                    <field name="help_salary" sum="Total" optional="show"/>
                                    <field name="overtime_salary" sum="Total" optional="show"/>
                                    <field name="excessive_overtime_deduction" sum="Total" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Salary Import List View -->
    <record id="view_salary_import_list" model="ir.ui.view">
        <field name="name">salary.import.list</field>
        <field name="model">salary.import</field>
        <field name="arch" type="xml">
            <list string="Salary Imports" 
                  decoration-success="state == 'posted'" 
                  decoration-info="state == 'imported'" 
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="date"/>
                <field name="create_date"/>
                <field name="journal_entry_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Salary Import Search View -->
    <record id="view_salary_import_search" model="ir.ui.view">
        <field name="name">salary.import.search</field>
        <field name="model">salary.import</field>
        <field name="arch" type="xml">
            <search string="Salary Imports">
                <field name="name"/>
                <field name="date"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="imported" string="Imported" domain="[('state', '=', 'imported')]"/>
                <filter name="posted" string="Posted" domain="[('state', '=', 'posted')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Salary Import Line List View -->
    <record id="view_salary_import_line_list" model="ir.ui.view">
        <field name="name">salary.import.line.list</field>
        <field name="model">salary.import.line</field>
        <field name="arch" type="xml">
            <list string="Salary Lines">
                <field name="import_id"/>
                <field name="partner_id"/>
                <field name="partner_vat"/>
                <field name="full_name"/>
                <field name="base_salary" sum="Total"/>
                <field name="total_salary" sum="Total"/>
                <field name="pension" sum="Total"/>
                <field name="company_tax" sum="Total"/>
                <field name="income_tax" sum="Total"/>
                <field name="net_amount" sum="Total"/>
            </list>
        </field>
    </record>

    <!-- Salary Import Line Search View -->
    <record id="view_salary_import_line_search" model="ir.ui.view">
        <field name="name">salary.import.line.search</field>
        <field name="model">salary.import.line</field>
        <field name="arch" type="xml">
            <search string="Salary Lines">
                <field name="partner_id"/>
                <field name="partner_vat"/>
                <field name="full_name"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="imported" string="Imported" domain="[('state', '=', 'imported')]"/>
                <filter name="posted" string="Posted" domain="[('state', '=', 'posted')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_import" string="Import" context="{'group_by': 'import_id'}"/>
                    <filter name="group_by_partner" string="Employee" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Salary Import Actions -->
    <record id="action_salary_import" model="ir.actions.act_window">
        <field name="name">Salary Imports</field>
        <field name="res_model">salary.import</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_salary_import_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new salary import
            </p>
            <p>
                Upload an Excel file with salary data to create journal entries.
            </p>
        </field>
    </record>

    <record id="action_salary_import_line" model="ir.actions.act_window">
        <field name="name">Salary Lines</field>
        <field name="res_model">salary.import.line</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_salary_import_line_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No salary lines found
            </p>
            <p>
                Import salary data to see lines here.
            </p>
        </field>
    </record>

    <!-- Server Action for Generate Journal Entries by Field -->
    <record id="action_server_generate_journal_entries_by_field" model="ir.actions.server">
        <field name="name">Generate Journal Entries (3139)</field>
        <field name="model_id" eval="ref('salary_management.model_salary_import')"/>
        <field name="binding_model_id" eval="ref('base.model_ir_model')"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
# Get salary import records from context
model_name = 'salary.import'
if 'active_model' in env.context:
    model_name = env.context['active_model']
    
if model_name == 'salary.import':
    records = env[model_name].browse(env.context.get('active_ids', []))
    if records:
        action = records.action_generate_journal_entries_by_field()
    else:
        action = False
else:
    action = False
        </field>
    </record>

</odoo>