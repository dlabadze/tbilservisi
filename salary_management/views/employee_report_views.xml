<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Employee Report List View -->
    <record id="view_employee_report_list" model="ir.ui.view">
        <field name="name">employee.report.list</field>
        <field name="model">employee.report</field>
        <field name="arch" type="xml">
            <list string="Employee Report" create="false" edit="false" delete="false">
                <field name="partner_name"/>
                <field name="partner_vat"/>
                <field name="total_salary" sum="Total Salary"/>
                <field name="base_salary" sum="Base Salary"/>
                <field name="net_amount" sum="Net Amount"/>
                <field name="pension" sum="Pension"/>
                <field name="income_tax" sum="Income Tax"/>
                <field name="company_tax" sum="Company Tax"/>
                <field name="salary_count"/>
                <field name="import_date"/>
                <field name="import_state"/>
            </list>
        </field>
    </record>

    <!-- Employee Report Form View -->
    <record id="view_employee_report_form" model="ir.ui.view">
        <field name="name">employee.report.form</field>
        <field name="model">employee.report</field>
        <field name="arch" type="xml">
            <form string="Employee Report" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="partner_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Employee Information">
                            <field name="partner_vat"/>
                            <field name="salary_count"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Import Information">
                            <field name="import_date"/>
                            <field name="import_ref"/>
                            <field name="import_state"/>
                        </group>
                    </group>
                    <group>
                        <group string="Salary Totals">
                            <field name="total_salary"/>
                            <field name="base_salary"/>
                            <field name="net_amount"/>
                        </group>
                        <group string="Deductions">
                            <field name="pension"/>
                            <field name="income_tax"/>
                            <field name="company_tax"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Employee Report Search View -->
    <record id="view_employee_report_search" model="ir.ui.view">
        <field name="name">employee.report.search</field>
        <field name="model">employee.report</field>
        <field name="arch" type="xml">
            <search string="Employee Report Search">
                <field name="partner_name" string="Employee Name"/>
                <field name="partner_vat" string="ID Number"/>
                <field name="import_date"/>
                <field name="import_state"/>
                <separator/>
                <filter name="posted" string="Posted" domain="[('import_state', '=', 'posted')]"/>
                <filter name="imported" string="Imported" domain="[('import_state', '=', 'imported')]"/>
                <filter name="draft" string="Draft" domain="[('import_state', '=', 'draft')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status" context="{'group_by': 'import_state'}"/>
                    <filter name="group_by_date" string="Import Date" context="{'group_by': 'import_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Employee Report Action - FIXED -->
    <record id="action_employee_report" model="ir.actions.act_window">
        <field name="name">Employee Report</field>
        <field name="res_model">employee.report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_employee_report_list"/>
        <field name="search_view_id" ref="view_employee_report_search"/>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No employee data found!
            </p>
            <p>
                This report shows all employees from salary imports with their totals.
                Import some salary data first to see employees here.
            </p>
        </field>
    </record>

</odoo>