<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_salary_batch_import_form" model="ir.ui.view">
        <field name="name">salary.batch.import.form</field>
        <field name="model">salary.batch.import</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post_entry" string="Post Entry" type="object" 
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_journal_entry" type="object" 
                                class="oe_stat_button" icon="fa-pencil-square-o" 
                                invisible="not journal_entry_id">
                            <span>Journal Entry</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="date"/>
                            <field name="amount"/>
                            <field name="reference"/>
                        </group>
                        <group>
                            <field name="journal_id" options="{'no_create': True}"/>
                            <field name="debit_account_id" options="{'no_create': True}"/>
                            <field name="credit_account_id" options="{'no_create': True}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="is_income_tax"/>
                            <field name="is_pension"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_salary_batch_import_list" model="ir.ui.view">
        <field name="name">salary.batch.import.list</field>
        <field name="model">salary.batch.import</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'posted'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="journal_id"/>
                <field name="reference"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_salary_batch_import_search" model="ir.ui.view">
        <field name="name">salary.batch.import.search</field>
        <field name="model">salary.batch.import</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="reference"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Posted" name="posted" domain="[('state', '=', 'posted')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Partner" name="group_by_partner" domain="[]" context="{'group_by': 'partner_id'}"/>
                    <filter string="Date" name="group_by_date" domain="[]" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_salary_batch_import" model="ir.actions.act_window">
        <field name="name">Salary Entries</field>
        <field name="res_model">salary.batch.import</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_salary_batch_import_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first salary entry
            </p>
        </field>
    </record>

</odoo>