<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Salary Payment Import Form View -->
    <record id="view_salary_payment_import_form" model="ir.ui.view">
        <field name="name">salary.payment.import.form</field>
        <field name="model">salary.payment.import</field>
        <field name="arch" type="xml">
            <form string="Salary Payment Import">
                <header>
                    <button name="action_import_excel" string="Import Excel" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <!-- <button name="action_generate_journal_entries" string="Generate Journal Entries" type="object" class="oe_highlight" invisible="state != 'imported'"/> -->
                    <button name="action_create_journal_entries_3139" string="Create Journal Entries (3139)" type="object" class="btn-primary" invisible="state != 'imported'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,imported,posted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_journal_entries" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="journal_entry_count == 0">
                            <field name="journal_entry_count" widget="statinfo" string="Journal Entries"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="department_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="excel_file" filename="excel_filename" required="state == 'draft'" readonly="state != 'draft'"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payment Lines">
                            <field name="line_ids" readonly="1">
                                <list string="Payment Lines">
                                    <field name="partner_name"/>
                                    <field name="partner_id"/>
                                    <field name="net_amount" sum="Total"/>
                                    <field name="debit" widget="char"/>
                                    <field name="credit" widget="char"/>
                                    <field name="column_description" string="ტიპი"/>
                                    <field name="credit_partner"/>
                                    <field name="credit_partner_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Salary Payment Import List View -->
    <record id="view_salary_payment_import_tree" model="ir.ui.view">
        <field name="name">salary.payment.import.tree</field>
        <field name="model">salary.payment.import</field>
        <field name="arch" type="xml">
            <list string="Salary Payment Imports" 
                  decoration-success="state=='posted'" 
                  decoration-info="state=='imported'" 
                  decoration-muted="state=='draft'">
                <field name="name"/>
                <field name="date"/>
                <field name="create_date"/>
                <field name="journal_entry_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Salary Payment Import Search View -->
    <record id="view_salary_payment_import_search" model="ir.ui.view">
        <field name="name">salary.payment.import.search</field>
        <field name="model">salary.payment.import</field>
        <field name="arch" type="xml">
            <search string="Salary Payment Imports">
                <field name="name"/>
                <field name="date"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Imported" name="imported" domain="[('state', '=', 'imported')]"/>
                <filter string="Posted" name="posted" domain="[('state', '=', 'posted')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_by_date" domain="[]" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Salary Payment Import Line List View -->
    <record id="view_salary_payment_import_line_tree" model="ir.ui.view">
        <field name="name">salary.payment.import.line.tree</field>
        <field name="model">salary.payment.import.line</field>
        <field name="arch" type="xml">
            <list string="Payment Lines">
                <field name="partner_name"/>
                <field name="partner_id"/>
                <field name="net_amount" sum="Total"/>
                <field name="debit" widget="char"/>
                <field name="credit" widget="char"/>
                <field name="credit_partner"/>
                <field name="credit_partner_id"/>
            </list>
        </field>
    </record>

    <!-- Salary Payment Import Line Search View -->
    <record id="view_salary_payment_import_line_search" model="ir.ui.view">
        <field name="name">salary.payment.import.line.search</field>
        <field name="model">salary.payment.import.line</field>
        <field name="arch" type="xml">
            <search string="Payment Lines">
                <field name="partner_name"/>
                <field name="partner_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Imported" name="imported" domain="[('state', '=', 'imported')]"/>
                <filter string="Posted" name="posted" domain="[('state', '=', 'posted')]"/>
                <group expand="0" string="Group By">
                    <filter string="Import" name="group_by_import" domain="[]" context="{'group_by': 'import_id'}"/>
                    <filter string="Partner" name="group_by_partner" domain="[]" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_by_state" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Salary Payment Import Actions -->
    <record id="action_salary_payment_import" model="ir.actions.act_window">
        <field name="name">Salary Payment Imports</field>
        <field name="res_model">salary.payment.import</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_salary_payment_import_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new salary payment import
            </p>
            <p>
                Upload an Excel file with payment data to create journal entries.
            </p>
        </field>
    </record>

    <record id="action_salary_payment_import_line" model="ir.actions.act_window">
        <field name="name">Payment Lines</field>
        <field name="res_model">salary.payment.import.line</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_salary_payment_import_line_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No payment lines found
            </p>
            <p>
                Import payment data to see lines here.
            </p>
        </field>
    </record>

    <!-- Server Action: Create Journal Entries (3139) -->
    <record id="action_server_create_journal_entries_3139" model="ir.actions.server">
        <field name="name">Create Journal Entries (3139)</field>
        <field name="model_id" eval="ref('salary_management.model_salary_payment_import')"/>
        <field name="binding_model_id" eval="ref('base.model_ir_model')"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
# Get salary payment import records from context
model_name = 'salary.payment.import'
if 'active_model' in env.context:
    model_name = env.context['active_model']
    
if model_name == 'salary.payment.import':
    records = env[model_name].browse(env.context.get('active_ids', []))
    if records:
        action = records.action_create_journal_entries_3139()
    else:
        action = False
else:
    action = False
        </field>
    </record>

</odoo>