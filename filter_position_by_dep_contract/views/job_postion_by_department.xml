<odoo>
  <data>
    <record id="view_hr_contract_form_filtered_jobs" model="ir.ui.view">
      <field name="name">hr.contract.form.filtered.jobs</field>
      <field name="model">hr.contract</field>
      <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
      <field name="arch" type="xml">

        <xpath expr="//field[@name='job_id'][@groups='!hr_contract.group_hr_contract_manager']" position="replace">
          <field name="job_id"
                 groups="!hr_contract.group_hr_contract_manager"
                 domain="[('id', 'in', available_job_ids)]"
                 options="{'no_open': True, 'no_create': True}"
                 placeholder="e.g. Sales Manager"/>
        </xpath>

        <xpath expr="//field[@name='job_id'][@groups='hr_contract.group_hr_contract_manager']" position="replace">
          <field name="job_id"
                 groups="hr_contract.group_hr_contract_manager"
                 domain="[('id', 'in', available_job_ids)]"
                 placeholder="e.g. Sales Manager"/>
        </xpath>

      </field>
    </record>
  </data>
</odoo>
