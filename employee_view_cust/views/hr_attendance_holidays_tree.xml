<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_employee_tree_attendance_custom" model="ir.ui.view">
        <field name="name">hr.employee.tree.attendance.custom</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr_attendance.view_employee_tree_inherit_leave"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='attendance_manager_id']" position="replace"/>
        </field>
    </record>

    <record id="hr_employee_tree_holidays_custom" model="ir.ui.view">
        <field name="name">hr.employee.tree.holidays.custom</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr_holidays.view_employee_tree_inherit_leave"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='leave_manager_id']" position="replace"/>
        </field>
    </record>

</odoo>
