<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_custom" model="ir.ui.view">
        <field name="name">hr.employee.form.custom</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//label[@for='private_street']" position="replace"/>
            <xpath expr="//field[@name='private_street']" position="replace"/>

            <xpath expr="//field[@name='mobile_phone']" position="after">
                <div class="o_address_format">
                    <field name="private_street" placeholder="Street... " string="ფაქტიური მისამართი"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>