<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree view for product lines -->
    <record id="view_fleet_service_product_line_tree" model="ir.ui.view">
        <field name="name">fleet.service.product.line.list</field>
        <field name="model">fleet.service.product.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="name" readonly="1"/>
                <field name="product_ref" readonly="1"/>
                <field name="barcode" readonly="1"/>
                <field name="uom_id" readonly="1"/>
                <field name="quantity"/>
                <field name="price_unit"/>
                <field name="subtotal" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- Form view for product lines -->
    <record id="view_fleet_service_product_line_form" model="ir.ui.view">
        <field name="name">fleet.service.product.line.form</field>
        <field name="model">fleet.service.product.line</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="service_id"/>
                    <field name="product_id"/>
                    <field name="name" readonly="1"/>
                    <field name="product_ref" readonly="1"/>
                    <field name="barcode" readonly="1"/>
                    <field name="uom_id" readonly="1"/>
                    <field name="quantity"/>
                    <field name="price_unit"/>
                    <field name="subtotal" readonly="1"/>
                </group>
            </form>
        </field>
    </record>

    <!-- Inherit fleet service form to add a Products page -->
    <record id="view_fleet_vehicle_log_services_form_inherit_product_lines" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.services.form.inherit.product.lines</field>
        <field name="model">fleet.vehicle.log.services</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_log_services_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Products" col="1">
                    <field name="product_line_ids" nolabel="1" colspan="1">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="product_ref" readonly="1"/>
                            <field name="barcode" readonly="1"/>
                            <field name="uom_id" readonly="1"/>
                            <field name="quantity"/>
                            <field name="price_unit"/>
                            <field name="subtotal" readonly="1"/>
                        </list>
                        <form>
                            <group>
                                <field name="product_id"/>
                                <field name="product_ref" readonly="1"/>
                                <field name="barcode" readonly="1"/>
                                <field name="uom_id" readonly="1"/>
                                <field name="quantity"/>
                                <field name="price_unit"/>
                                <field name="subtotal" readonly="1"/>
                            </group>
                        </form>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>


