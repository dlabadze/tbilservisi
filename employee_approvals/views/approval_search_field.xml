<odoo>
    <record id="approval_request_view_tree_inherit_create" model="ir.ui.view">
        <field name="name">approval.request.list.inherit.create</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="create">true</attribute>
            </xpath>
        </field>
    </record>

    <record id="approval_request_view_search_inherit" model="ir.ui.view">
        <field name="name">approval.request.search.inherit</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_search_view_search"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <filter string="Employee" name="filter_brdzaneba_employee" domain="[('brdzaneba_employee_id', '=', context.get('active_id'))]"/>
                    <field name="brdzaneba_employee_id"/>
                </xpath>
            </field>
    </record>


</odoo>