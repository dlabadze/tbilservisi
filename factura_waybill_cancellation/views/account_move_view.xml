<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_move_form_cancel_factura" model="ir.ui.view">
        <field name="name">account.move.form.cancel.factura</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='button_factura']" position="after">
                <button name="cancel_factura" 
                        string="გაუქმება ფაქტურა" 
                        type="object"
                        class="btn-danger"
                        invisible="not factura_num"/>
            </xpath>
        </field>
    </record>
</odoo>
