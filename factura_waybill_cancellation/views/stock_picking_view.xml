<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_picking_form_cancel_waybill" model="ir.ui.view">
        <field name="name">stock.picking.form.cancel.waybill</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="cancel_waybill" 
                        string="გაუქმება ზედნადები" 
                        type="object"
                        class="btn-danger"
                        invisible="not invoice_id"
                        confirm="გსურთ ზედნადების გაუქმება (ref_waybill)?"/>
            </xpath>
        </field>
    </record>
</odoo>
